"Test status with a real project created through services\\\"\\\"\\\"\\n    62→        services = real_services.get_all()\\n    63→        \\n    64→        # Create a real project using project service\\n    65→        project_id = services['project'].create_project(\\\"Integration Test Project\\\", {})\\n    66→        \\n    67→        # Add the project to state\\n    68→        services['state'].add_project(project_id, \\\"Integration Test Project\\\")\\n    69→        services['state'].set_active_project(project_id)\\n    70→        \\n    71→        # Add a real note to the project\\n    72→        services['project'].add_note(project_id, \\\"This is a test note for integration testing\\\")\\n    73→        \\n    74→        # Create command\\n    75→        command = StatusCommand(services)\\n    76→        \\n    77→        # Mock Telegram update/context\\n    78→        update = Mock()\\n    79→        update.message = Mock()\\n    80→        update.message.reply_text = AsyncMock()\\n    81→        context = Mock()\\n    82→        \\n    83→        # Execute command\\n    84→        await command.execute(update, context)\\n    85→        \\n    86→        # Verify response includes real project data\\n    87→        update.message.reply_text.assert_called_once()\\n    88→        message_text = update.message.reply_text.call_args[0][0]\\n    89→        \\n    90→        assert \\\"Integration Test Project\\\" in message_text\\n    91→        assert \\\"Messages: 1\\\" in message_text\\n    92→        assert \\\"Total words:\\\" in message_text\\n    93→        assert \\\"English\\\" in message_text  # Default language\\n    94→        \\n    95→        # Verify the project file actually exists\\n    96→        project_dir = services['project'].get_project_dir(project_id)\\n    97→        assert project_dir.exists()\\n    98→        notes_file = project_dir / \\\"notes.md\\\"\\n    99→        assert notes_file.exists()\\n   100→        \\n   101→        # Verify note content\\n   102→        notes_content = notes_file.read_text()\\n   103→        assert \\\"Integration Test Project\\\" in notes_content\\n   104→        assert \\\"This is a test note for integration testing\\\" in notes_content\\n   105→\\n   106→\\n   107→class TestNewProjectCommandReal:\\n   108→    \\\"\\\"\\\"Test new project command with real services\\\"\\\"\\\"\\n   109→    \\n   110→    @pytest.mark.integration\\n   111→    @pytest.mark.asyncio\\n   112→    async def test_create_project_real_workflow(self, real_services):\\n   113→        \\\"\\\"\\\"Test complete project creation workflow with real services\\\"\\\"\\\"\\n   114→        services = real_services.get_all()\\n   115→        command = NewProjectCommand(services)\\n   116→        \\n   117→        # Mock Telegram update/context with project name\\n   118→        update = Mock()\\n   119→        update.message = Mock()\\n   120→        update.message.reply_text = AsyncMock()\\n   121→        context = Mock()\\n   122→        context.args = [\\\"Real\\\", \\\"Integration\\\", \\\"Project\\\"]\\n   123→        \\n   124→        # Get initial project count\\n   125→        initial_projects = services['state'].get_projects()\\n   126→        initial_count = len(initial_projects)\\n   127→        \\n   128→        # Execute command\\n   129→        await command.execute(update, context)\\n   130→        \\n   131→        # Verify success response\\n   132→        update.message.reply_text.assert_called_once()\\n   133→        message_text = update.message.reply_text.call_args[0][0]\\n   134→        assert \\\"Created project\\\" in message_text\\n   135→        assert \\\"Real Integration Project\\\" in message_text\\n   136→        \\n   137→        # Verify project was actually created in state\\n   138→        projects = services['state'].get_projects()\\n   139→        assert len(projects) == initial_count + 1\\n   140→        \\n   141→        # Find the new project\\n   142→        new_project_id = None\\n   143→        for pid, name in projects.items():\\n   144→            if name == \\\"Real Integration Project\\\":\\n   145→                new_project_id = pid\\n   146→                break\\n   147→        \\n   148→        assert new_project_id is not None\\n   149→        \\n   150→        # Verify project directory and files exist\\n   151→        project_dir = services['project'].get_project_dir(new_project_id)\\n   152→        assert project_dir.exists()\\n   153→        assert project_dir.name.startswith(f\\\"project-{new_project_id}-\\\")\\n   154→        \\n   155→        notes_file = project_dir / \\\"notes.md\\\"\\n   156→        assert notes_file.exists()\\n   157→        \\n   158→        # Verify notes file content\\n   159→        notes_content = notes_file.read_text()\\n   160→        assert \\\"# Real Integration Project\\\" in notes_content\\n   161→        assert \\\"Voice notes transcriptions:\\\" in notes_content\\n   162→    \\n   163→    @pytest.mark.integration\\n   164→    @pytest.mark.asyncio\\n   165→    async def test_create_project_no_args_error(self, real_services):\\n   166→        \\\"\\\"\\\"Test project creation error handling with real services\\\"\\\"\\\"\\n   167→        services = real_services.get_all()\\n   168→        command = NewProjectCommand(services)\\n   169→        \\n   170→        # Mock Telegram update/context without args\\n   171→        update = Mock()\\n   172→        update.message = Mock()\\n   173→        update.message.reply_text = AsyncMock()\\n   174→        context = Mock()\\n   175→        context.args = []  # No project name\\n   176→        \\n   177→        # Execute command\\n   178→        await command.execute(update, context)\\n   179→        \\n   180→        # Verify error response\\n   181→        update.message.reply_text.assert_called_once()\\n   182→        message_text = update.message.reply_text.call_args[0][0]\\n   183→        assert \\\"Usage:\\\" in message_text\\n   184→\\n   185→\\n   186→class TestLanguageCommandReal:\\n   187→    \\\"\\\"\\\"Test language command with real state management\\\"\\\"\\\"\\n   188→    \\n   189→    @pytest.mark.integration\\n   190→    @pytest.mark.asyncio\\n   191→    async def test_language_change_real_state(self, real_services):\\n   192→        \\\"\\\"\\\"Test language change with real state persistence\\\"\\\"\\\"\\n   193→        services = real_services.get_all()\\n   194→        command = LanguageCommand(services)\\n   195→        \\n   196→        # Verify initial language\\n   197→        assert services['state'].get_language() == \\\"en\\\"\\n   198→        \\n   199→        # Mock callback query for Bulgarian\\n   200→        query = Mock()\\n   201→        query.data = \\\"lang_bg\\\"\\n   202→        query.answer = AsyncMock()\\n   203→        query.edit_message_text = AsyncMock()\\n   204→        \\n   205→        update = Mock()\\n   206→        update.callback_query = query\\n   207→        context = Mock()\\n   208→        \\n   209→        # Execute callback\\n   210→        await command.handle_callback(update, context)\\n   211→        \\n   212→        # Verify language was actually changed in state\\n   213→        assert services['state'].get_language() == \\\"bg\\\"\\n   214→        \\n   215→        # Verify response\\n   216→        query.answer.assert_called_once()\\n   217→        query.edit_message_text.assert_called_once()\\n   218→        \\n   219→        # Verify state persistence by creating new service container\\n   220→        state_file = services['config']['state_file']\\n   221→        new_container = ServiceContainer(services['config'])\\n   222→        assert new_container.get('state').get_language() == \\\"bg\\\"\\n   223→\\n   224→\\n   225→class TestProjectsCommandReal:\\n   226→    \\\"\\\"\\\"Test projects command with real project management\\\"\\\"\\\"\\n   227→    \\n   228→    @pytest.mark.integration\\n   229→    @pytest.mark.asyncio\\n   230→    async def test_project_selection_real_workflow(self, real_services):\\n   231→        \\\"\\\"\\\"Test project selection with real services\\\"\\\"\\\"\\n   232→        services = real_services.get_all()\\n   233→        \\n   234→        # Create real projects\\n   235→        project1_id = services['project'].create_project(\\\"Project Alpha\\\", {})\\n   236→        project2_id = services['project'].create_project(\\\"Project Beta\\\", {\\\"001\\\": \\\"Project Alpha\\\"})\\n   237→        \\n   238→        services['state'].add_project(project1_id, \\\"Project Alpha\\\")\\n   239→        services['state'].add_project(project2_id, \\\"Project Beta\\\")\\n   240→        \\n   241→        command = ProjectsCommand(services)\\n   242→        \\n   243→        # Mock callback for selecting project 2\\n   244→        query = Mock()\\n   245→        query.data = f\\\"pick_{project2_id}\\\"\\n   246→        query.answer = AsyncMock()\\n   247→        query.edit_message_text = AsyncMock()\\n   248→        \\n   249→        update = Mock()\\n   250→        update.callback_query = query\\n   251→        context = Mock()\\n   252→        \\n   253→        # Execute selection\\n   254→        await command.handle_callback(update, context)\\n   255→        \\n   256→        # Verify project was actually selected\\n   257→        assert services['state'].get_active_project() == project2_id\\n   258→        \\n   259→        # Verify response\\n   260→        query.edit_message_text.assert_called_once()\\n   261→        response_text = query.edit_message_text.call_args[0][0]\\n   262→        assert \\\"Selected project\\\" in response_text\\n   263→        assert \\\"Project Beta\\\" in response_text\\n   264→    \\n   265→    @pytest.mark.integration\\n   266→    @pytest.mark.asyncio\\n   267→    async def test_project_archival_real_filesystem(self, real_services):\\n   268→        \\\"\\\"\\\"Test project archival with real file operations\\\"\\\"\\\"\\n   269→        services = real_services.get_all()\\n   270→        \\n   271→        # Create and populate a real project\\n   272→        project_id = services['project'].create_project(\\\"Project to Archive\\\", {})\\n   273→        services['state'].add_project(project_id, \\\"Project to Archive\\\")\\n   274→        \\n   275→        # Add some content\\n   276→        services['project'].add_note(project_id, \\\"This project will be archived\\\")\\n   277→        \\n   278→        # Verify project exists\\n   279→        project_dir = services['project'].get_project_dir(project_id)\\n   280→        assert project_dir.exists()\\n   281→        \\n   282→        command = ProjectsCommand(services)\\n   283→        \\n   284→        # Mock archival confirmation callback\\n   285→        query = Mock()\\n   286→        query.data = f\\\"confirm_del_{project_id}\\\"\\n   287→        query.answer = AsyncMock()\\n   288→        query.edit_message_text = AsyncMock()\\n   289→        \\n   290→        update = Mock()\\n   291→        update.callback_query = query\\n   292→        context = Mock()\\n   293→        \\n   294→        # Execute archival\\n   295→        await command.handle_callback(update, context)\\n   296→        \\n   297→        # Verify project directory was actually moved/deleted\\n   298→        assert not project_dir.exists()\\n   299→        \\n   300→        # Verify archive directory exists\\n   301→        projects_dir = Path(services['config']['projects_dir'])\\n   302→        archive_dir = projects_dir.parent / \\\"archive\\\"\\n   303→        assert archive_dir.exists()\\n   304→        \\n   305→        # Verify project was archived\\n   306→        archived_projects = list(archive_dir.glob(f\\\"project-{project_id}-*\\\"))\\n   307→        assert len(archived_projects) == 1\\n   308→\\n   309→\\n   310→class TestVoiceMessageHandlerReal:\\n   311→    \\\"\\\"\\\"Test voice message handling with real services (mocked Telegram API only)\\\"\\\"\\\"\\n   312→    \\n   313→    @pytest.mark.integration\\n   314→    @pytest.mark.asyncio\\n   315→    async def test_voice_processing_real_workflow_no_audio(self, real_services):\\n   316→        \\\"\\\"\\\"Test voice message processing workflow without actual audio transcription\\\"\\\"\\\"\\n   317→        services = real_services.get_all()\\n   318→        \\n   319→        # Create real project first\\n   320→        project_id = services['project'].create_project(\\\"Voice Test Project\\\", {})\\n   321→        services['state'].add_project(project_id, \\\"Voice Test Project\\\")\\n   322→        services['state'].set_active_project(project_id)\\n   323→        \\n   324→        handler = VoiceMessageHandler(services)\\n   325→        \\n   326→        # Mock Telegram voice message (but skip actual audio processing)\\n   327→        voice_file = Mock()\\n   328→        voice_file.get_file = AsyncMock()\\n   329→        mock_file = Mock()\\n   330→        mock_file.download_to_drive = AsyncMock()\\n   331→        voice_file.get_file.return_value = mock_file\\n   332→        \\n   333→        update = Mock()\\n   334→        update.message = Mock()\\n   335→        update.message.message_id = 12345\\n   336→        update.message.voice = voice_file\\n   337→        update.message.reply_text = AsyncMock()\\n   338→        \\n   339→        processing_msg = Mock()\\n   340→        processing_msg.edit_text = AsyncMock()\\n   341→        update.message.reply_text.return_value = processing_msg\\n   342→        \\n   343→        context = Mock()\\n   344→        \\n   345→        # Mock transcription for this test (to avoid slow real transcription)\\n   346→        original_transcribe = services['transcription'].transcribe_audio\\n   347→        \\n   348→        async def mock_transcribe(audio_path, language):\\n   349→            return \\\"This is a mocked transcription for integration testing\\\", language\\n   350→        \\n   351→        services['transcription'].tr