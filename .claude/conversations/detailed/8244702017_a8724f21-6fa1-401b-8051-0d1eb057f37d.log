    "content": "     1→\"\"\"\n     2→Performance and benchmarking tests for the transcription system\n     3→\n     4→These tests measure actual performance characteristics of the real system\n     5→components to ensure they meet performance requirements.\n     6→\"\"\"\n     7→import pytest\n     8→import time\n     9→import asyncio\n    10→from pathlib import Path\n    11→import statistics\n    12→from typing import List, Dict, Any\n    13→\n    14→from src.services.transcription import TranscriptionService\n    15→from src.services.container import ServiceContainer\n    16→from tests.audio_helpers import AudioGenerator\n    17→\n    18→\n    19→class TestTranscriptionPerformanceBenchmarks:\n    20→    \"\"\"Benchmark transcription performance with real Whisper models\"\"\"\n    21→    \n    22→    @pytest.mark.performance\n    23→    @pytest.mark.transcription\n    24→    @pytest.mark.slow\n    25→    @pytest.mark.asyncio\n    26→    async def test_whisper_model_loading_benchmark(self, temp_dir):\n    27→        \"\"\"Benchmark Whisper model loading times for different models\"\"\"\n    28→        models_to_test = [\"tiny\", \"base\"]  # Don't test larger models in CI\n    29→        results = {}\n    30→        \n    31→        for model_name in models_to_test:\n    32→            # Test model loading time\n    33→            service = TranscriptionService(model_name=model_name, audio_dir=temp_dir / \"audio\")\n    34→            \n    35→            start_time = time.time()\n    36→            service._load_model()\n    37→            load_time = time.time() - start_time\n    38→            \n    39→            results[model_name] = load_time\n    40→            \n    41→            # Verify model loaded correctly\n    42→            assert service.model is not None\n    43→            \n    44→            print(f\"{model_name} model loading time: {load_time:.2f}s\")\n    45→        \n    46→        # Performance assertions\n    47→        assert results[\"tiny\"] < 30.0, f\"Tiny model loading too slow: {results['tiny']:.2f}s\"\n    48→        if \"base\" in results:\n    49→            assert results[\"base\"] < 60.0, f\"Base model loading too slow: {results['base']:.2f}s\"\n    50→        \n    51→        print(f\"Model loading benchmark results: {results}\")\n    52→    \n    53→    @pytest.mark.performance\n    54→    @pytest.mark.transcription\n    55→    @pytest.mark.slow\n    56→    @pytest.mark.asyncio\n    57→    async def test_transcription_speed_benchmark(self, real_transcription_service, audio_generator, temp_dir):\n    58→        \"\"\"Benchmark transcription speed for different audio durations\"\"\"\n    59→        service = real_transcription_service\n    60→        \n    61→        # Test different audio durations\n    62→        durations = [1.0, 2.0, 5.0]  # seconds\n    63→        audio_types = ['silence', 'tone', 'speech']\n    64→        \n    65→        results = {}\n    66→        \n    67→        for duration in durations:\n    68→            duration_results = {}\n    69→            \n    70→            for audio_type in audio_types:\n    71→                # Create test audio\n    72→                if audio_type == 'silence':\n    73→                    audio_data = audio_generator.generate_silence(duration)\n    74→                elif audio_type == 'tone':\n    75→                    audio_data = audio_generator.generate_tone(440.0, duration)\n    76→                else:  # speech\n    77→                    audio_data = audio_generator.generate_speech_like_audio(duration)\n    78→                \n    79→                audio_file = audio_generator.create_wav_file(\n    80→                    audio_data, temp_dir / f\"perf_{audio_type}_{duration}s.wav\"\n    81→                )\n    82→                \n    83→                try:\n    84→                    # Benchmark transcription\n    85→                    start_time = time.time()\n    86→                    text, language = await service.transcribe_audio(audio_file, \"en\")\n    87→                    transcription_time = time.time() - start_time\n    88→                    \n    89→                    duration_results[audio_type] = {\n    90→                        'time': transcription_time,\n    91→                        'text_length': len(text),\n    92→                        'speed_ratio': transcription_time / duration\n    93→                    }\n    94→                    \n    95→                finally:\n    96→                    if audio_file.exists():\n    97→                        audio_file.unlink()\n    98→            \n    99→            results[duration] = duration_results\n   100→        \n   101→        # Print benchmark results\n   102→        print(\"\\n=== Transcription Speed Benchmark ===\")\n   103→        for duration, types in results.items():\n   104→            print(f\"\\n{duration}s audio:\")\n   105→            for audio_type, metrics in types.items():\n   106→                print(f\"  {audio_type}: {metrics['time']:.2f}s \"\n   107→                     f\"(ratio: {metrics['speed_ratio']:.2f}x, \"\n   108→                     f\"output: {metrics['text_length']} chars)\")\n   109→        \n   110→        # Performance assertions\n   111→        for duration, types in results.items():\n   112→            for audio_type, metrics in types.items():\n   113→                # Transcription should not take more than 10x the audio duration\n   114→                max_time = duration * 10\n   115→                assert metrics['time'] < max_time, \\\n   116→                    f\"{audio_type} {duration}s took too long: {metrics['time']:.2f}s\"\n   117→    \n   118→    @pytest.mark.performance\n   119→    @pytest.mark.asyncio\n   120→    async def test_concurrent_transcription_performance(self, real_transcription_service, audio_generator, temp_dir):\n   121→        \"\"\"Test performance under concurrent transcription load\"\"\"\n   122→        service = real_transcription_service\n   123→        \n   124→        # Create multiple audio files\n   125→        audio_files = []\n   126→        for i in range(3):  # Test with 3 concurrent transcriptions\n   127→            audio_data = audio_generator.generate_silence(2.0)\n   128→            audio_file = audio_generator.create_wav_file(\n   129→                audio_data, temp_dir / f\"concurrent_{i}.wav\"\n   130→            )\n   131→            audio_files.append(audio_file)\n   132→        \n   133→        try:\n   134→            # Test sequential transcription\n   135→            sequential_start = time.time()\n   136→            for audio_file in audio_files:\n   137→                await service.transcribe_audio(audio_file, \"en\")\n   138→            sequential_time = time.time() - sequential_start\n   139→            \n   140→            # Test concurrent transcription\n   141→            concurrent_start = time.time()\n   142→            tasks = [service.transcribe_audio(audio_file, \"en\") for audio_file in audio_files]\n   143→            await asyncio.gather(*tasks)\n   144→            concurrent_time = time.time() - concurrent_start\n   145→            \n   146→            print(f\"Sequential transcription: {sequential_time:.2f}s\")\n   147→            print(f\"Concurrent transcription: {concurrent_time:.2f}s\")\n   148→            print(f\"Speedup: {sequential_time / concurrent_time:.2f}x\")\n   149→            \n   150→            # Concurrent should not be significantly slower than sequential\n   151→            # (Whisper model is CPU-bound, so we don't expect major speedup)\n   152→            assert concurrent_time < sequential_time * 1.5, \\\n   153→                \"Concurrent transcription significantly slower than sequential\"\n   154→            \n   155→        finally:\n   156→            # Cleanup\n   157→            for audio_file in audio_files:\n   158→                if audio_file.exists():\n   159→                    audio_file.unlink()\n   160→\n   161→\n   162→class TestServicePerformanceBenchmarks:\n   163→    \"\"\"Benchmark service layer performance\"\"\"\n   164→    \n   165→    @pytest.mark.performance\n   166→    @pytest.mark.integration\n   167→    def test_state_service_performance(self, temp_dir):\n   168→        \"\"\"Benchmark state service operations\"\"\"\n   169→        from src.services.state import StateService\n   170→        \n   171→        state_file = temp_dir / \"perf_state.json\"\n   172→        service = StateService(state_file)\n   173→        \n   174→        # Benchmark project operations\n   175→        num_projects = 100\n   176→        \n   177→        # Time project additions\n   178→        start_time = time.time()\n   179→        for i in range(num_projects):\n   180→            service.add_project(f\"project_{i:03d}\", f\"Project {i}\")\n   181→        add_time = time.time() - start_time\n   182→        \n   183→        # Time project retrievals\n   184→        start_time = time.time()\n   185→        for _ in range(100):\n   186→            projects = service.get_projects()\n   187→        get_time = time.time() - start_time\n   188→        \n   189→        # Time message processing tracking\n   190→        start_time = time.time()\n   191→        for i in range(1000):\n   192→            service.mark_message_processed(f\"msg_{i}\")\n   193→        message_time = time.time() - start_time\n   194→        \n   195→        print(f\"State service performance:\")\n   196→        print(f\"  Add {num_projects} projects: {add_time:.3f}s ({add_time/num_projects*1000:.1f}ms each)\")\n   197→        print(f\"  100 project retrievals: {get_time:.3f}s ({get_time/100*1000:.1f}ms each)\")\n   198→        print(f\"  1000 message marks: {message_time:.3f}s ({message_time/1000*1000:.1f}ms each)\")\n   199→        \n   200→        # Performance assertions\n   201→        assert add_time < 1.0, f\"Adding {num_projects} projects too slow: {add_time:.3f}s\"\n   202→        assert get_time < 0.5, f\"100 project retrievals too slow: {get_time:.3f}s\"\n   203→        assert message_time < 0.5, f\"1000 message marks too slow: {message_time:.3f}s\"\n   204→    \n   205→    @pytest.mark.performance\n   206→    @pytest.mark.integration\n   207→    def test_project_service_performance(self, temp_dir):\n   208→        \"\"\"Benchmark project service file operations\"\"\"\n   209→        from src.services.project import ProjectService\n   210→        \n   211→        projects_dir = temp_dir / \"projects\"\n   212→        service = ProjectService(projects_dir)\n   213→        \n   214→        # Time project creation\n   215→        num_projects = 20\n   216→        project_ids = []\n   217→        \n   218→        start_time = time.time()\n   219→        for i in range(num_projects):\n   220→            project_id = service.create_project(f\"Perf Project {i}\", {})\n   221→            project_ids.append(project_id)\n   222→        creation_time = time.time() - start_time\n   223→        \n   224→        # Time note addition\n   225→        notes_per_project = 10\n   226→        start_time = time.time()\n   227→        for project_id in project_ids:\n   228→            for j in range(notes_per_project):\n   229→                service.add_note(project_id, f\"Performance test note {j} for project {project_id}\")\n   230→        note_time = time.time() - start_time\n   231→        \n   232→        # Time statistics calculation\n   233→        start_time = time.time()\n   234→        for project_id in project_ids:\n   235→            service.get_project_stats(project_id)\n   236→        stats_time = time.time() - start_time\n   237→        \n   238→        total_notes = num_projects * notes_per_project\n   239→        \n   240→        print(f\"Project service performance:\")\n   241→        print(f\"  Create {num_projects} projects: {creation_time:.3f}s ({creation_time/num_projects*1000:.1f}ms each)\")\n   242→        print(f\"  Add {total_notes} notes: {note_time:.3f}s ({note_time/total_notes*1000:.1f}ms each)\")\n   243→        print(f\"  Calculate {num_projects} stats: {stats_time:.3f}s ({stats_time/num_projects*1000:.1f}ms each)\")\n   244→        \n   245→        # Performance assertions\n   246→        assert creation_time < 5.0, f\"Creating {num_projects} projects too slow: {creation_time:.3f}s\"\n   247→        assert note_time < 5.0, f\"Adding {total_notes} notes too slow: {note_time:.3f}s\"\n   248→        assert stats_time < 2.0, f\"Calculating {num_projects} stats too slow: {stats_time:.3f}s\"\n   249→    \n   250→    @pytest.mark.performance\n   251→    @pytest.mark.integration\n   252→    def test_service_container_initialization_performance(self, test_config):\n   253→        \"\"\"Benchmark service container initialization\"\"\"\n   254→        num_initializations = 10\n   255→        times = []\n   256→        \n   257→        for i in range(num_initializations):\n   258→            start_time = time.time()\n   259→            container = ServiceContainer(test_config)\n   260→            # Get all services to ensure they're initialized\n   261→            services = container.get_all()\n   262→            initialization_time = time.time() - start_time\n   263→            times.append(initialization_time)\n   264→        \n   265→        avg_time = statistics.mean(times)\n   266→        min_time = min(times)\n   267→        max_time = max(times)\n   268→        \n   269→        print(f\"Service container initialization performance:\")\n   270→        print(f\"  Average: {avg_time:.3f}s\")\n   271→        print(f\"  Min: {min_time:.3f}s\")\n   272→        print(f\"  Max: {max_time:.3f}s\")\n   273→        print(f\"  All times: {[f'{t:.3f}' for t in times]}\")\n   274→        \n   275→        # Performance assertions\n   276→        assert avg_time < 2.0, f\"Service container initialization too slow: {avg_time:.3f}s\"\n   277→        assert max_time < 5.0, f\"Slowest initialization too slow: {max_time:.3f}s\"\n   278→\n   279→\n   280→class TestMemoryUsageBenchmarks:\n   281→    \"\"\"Test memory usage characteristics (basic monitoring)\"\"\"\n   282→    \n   283→    @pytest.mark.performance\n   284→    @pytest.mark.slow\n   285→    def test_transcription_service_memory_usage(self, temp_dir):\n   286→        \"\"\"Monitor memory usage of transcription service operations\"\"\"\n   287→        import psutil\n   288→        import os\n   289→        \n   290→        process = psutil.Process(os.getpid())\n   291→        \n   292→        # Baseline memory\n   293→        baseline_memory = process.memory_info().rss / 1024 / 1024  # MB\n   294→        \n   295→        # Create transcription service (should load model)\n   296→        service = TranscriptionService(model_name=\"tiny\", audio_dir=temp_dir / \"audio\")\n   297→        service._load_model()\n   298→        \n   299→        # Memory after model loading\n   300→        model_memory = process.memory_info().rss / 1024 / 1024  # MB\n   301→        memory_increase = model_memory - baseline_memory\n   302→        \n   303→        print(f\"Memory usage benchmark:\")\n   304→        print(f\"  Baseline: {baseline_memory:.1f} MB\")\n   305→        print(f\"  After tiny model load: {model_memory:.1f} MB\")\n   306→        print(f\"  Model memory overhead: {memory_increase:.1f} MB\")\n   307→        \n   308→        # Memory usage should be reasonable for tiny model\n   309→        assert memory_increase < 500, f\"Tiny model uses too much memory: {memory_increase:.1f} MB\"\n   310→        \n   311→        # Cleanup\n   312→        del service\n   313→    \n   314→    @pytest.mark.performance\n   315→    @pytest.mark.integration\n   316→    def test_large_project_memory_usage(self, temp_dir):\n   317→        \"\"\"Test memory usage with large project files\"\"\"\n   318→        import psutil\n   319→        import os\n   320→        \n   321→        from src.services.project import ProjectService\n   322→        \n   323→        process = psutil.Process(os.getpid())\n   324→        baseline_memory = process.memory_info().rss / 1024 / 1024  # MB\n   325→        \n   326→        projects_dir = temp_dir / \"projects\"\n   327→        service = ProjectService(projects_dir)\n   328→        \n   329→        # Create project with many notes\n   330→        project_id = service.create_project(\"Large Project\", {})\n   331→        \n   332→        # Add many notes to simulate large project\n   333→        for i in range(500):  # 500 notes\n   334→            long_text = f\"This is note {i} with some longer text content to simulate realistic note sizes. \" * 5\n   335→            service.add_note(project_id, long_text)\n   336→        \n   337→        # Check memory after large project operations\n   338→        final_memory = process.memory_info().rss / 1024 / 1024  # MB\n   339→        memory_increase = final_memory - baseline_memory\n   340→        \n   341→        # Test reading project stats (should not load entire file into memory persistently)\n   342→        for _ in range(10):\n   343→            service.get_project_stats(project_id)\n   344→        \n   345→        stats_memory = process.memory_info().rss / 1024 / 1024  # MB\n   346→        stats_increase = stats_memory - baseline_memory\n   347→        \n   348→        print(f\"Large project memory usage:\")\n   349→        print(f\"  Baseline: {baseline_memory:.1f} MB\")\n   350→        print(f\"  After 500 notes: {final_memory:.1f} MB (+{memory_increase:.1f} MB)\")\n   351→        print(f\"  After stats operations: {stats_memory:.1f} MB (+{stats_increase:.1f} MB)\")\n   352→        \n   353→        # Memory increases should be reasonable\n   354→        assert memory_increase < 100, f\"Large project uses too much memory: {memory_increase:.1f} MB\"\n   355→        assert stats_increase < 120, f\"Stats operations leak memory: {stats_increase:.1f} MB\"\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
