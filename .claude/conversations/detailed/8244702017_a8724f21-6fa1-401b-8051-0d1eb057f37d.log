               update_voice = Mock()\n   327→                update_voice.message = Mock()\n   328→                update_voice.message.message_id = f\"msg_{i}\"\n   329→                update_voice.message.voice = voice_file\n   330→                update_voice.message.reply_text = AsyncMock()\n   331→                \n   332→                processing_msg = Mock()\n   333→                processing_msg.edit_text = AsyncMock()\n   334→                update_voice.message.reply_text.return_value = processing_msg\n   335→                \n   336→                context_voice = Mock()\n   337→                \n   338→                # Process the voice message\n   339→                await handler.handle_voice(update_voice, context_voice)\n   340→                \n   341→                # Verify processing\n   342→                assert services['state'].is_message_processed(f\"msg_{i}\")\n   343→                \n   344→            finally:\n   345→                if audio_file.exists():\n   346→                    audio_file.unlink()\n   347→        \n   348→        # Step 4: Check final status\n   349→        status_cmd = StatusCommand(services)\n   350→        update_status = Mock()\n   351→        update_status.message = Mock()\n   352→        update_status.message.reply_text = AsyncMock()\n   353→        context_status = Mock()\n   354→        \n   355→        await status_cmd.execute(update_status, context_status)\n   356→        \n   357→        # Verify status shows correct information\n   358→        status_text = update_status.message.reply_text.call_args[0][0]\n   359→        assert \"My First Project\" in status_text\n   360→        assert \"Messages: 2\" in status_text  # Two voice messages processed\n   361→        assert \"English\" in status_text\n   362→        \n   363→        # Step 5: Verify project file contents\n   364→        project_dir = services['project'].get_project_dir(project_id)\n   365→        notes_file = project_dir / \"notes.md\"\n   366→        notes_content = notes_file.read_text()\n   367→        \n   368→        # Should have project header and two timestamped entries\n   369→        assert \"# My First Project\" in notes_content\n   370→        timestamp_count = notes_content.count(\"##\")\n   371→        assert timestamp_count == 2  # Two voice messages\n   372→        \n   373→        # Verify project statistics\n   374→        messages, words = services['project'].get_project_stats(project_id)\n   375→        assert messages == 2\n   376→        assert words >= 0  # Word count depends on what Whisper outputs for our test audio\n   377→        \n   378→        print(f\"Complete workflow test successful!\")\n   379→        print(f\"Final project stats: {messages} messages, {words} words\")\n   380→        print(f\"Final notes content:\\n{notes_content}\")\n   381→\n   382→\n   383→class TestEndToEndStateManagement:\n   384→    \"\"\"Test state persistence and management across the complete pipeline\"\"\"\n   385→    \n   386→    @pytest.mark.integration\n   387→    @pytest.mark.asyncio\n   388→    async def test_state_persistence_across_operations(self, test_config, temp_dir):\n   389→        \"\"\"Test that state persists correctly across multiple service container instances\"\"\"\n   390→        \n   391→        # Create first service container\n   392→        container1 = ServiceContainer(test_config)\n   393→        services1 = container1.get_all()\n   394→        \n   395→        # Create project and set language\n   396→        project_id = services1['project'].create_project(\"Persistence Test\", {})\n   397→        services1['state'].add_project(project_id, \"Persistence Test\")\n   398→        services1['state'].set_active_project(project_id)\n   399→        services1['state'].set_language(\"bg\")\n   400→        services1['state'].mark_message_processed(\"test_msg_1\")\n   401→        \n   402→        # Add note to project\n   403→        services1['project'].add_note(project_id, \"Test note for persistence\")\n   404→        \n   405→        # Create second service container (simulates bot restart)\n   406→        container2 = ServiceContainer(test_config)\n   407→        services2 = container2.get_all()\n   408→        \n   409→        # Verify all state persisted\n   410→        assert services2['state'].get_language() == \"bg\"\n   411→        assert services2['state'].get_active_project() == project_id\n   412→        assert services2['state'].is_message_processed(\"test_msg_1\")\n   413→        \n   414→        projects = services2['state'].get_projects()\n   415→        assert project_id in projects\n   416→        assert projects[project_id] == \"Persistence Test\"\n   417→        \n   418→        # Verify project file persisted\n   419→        project_dir = services2['project'].get_project_dir(project_id)\n   420→        assert project_dir.exists()\n   421→        \n   422→        notes_file = project_dir / \"notes.md\"\n   423→        notes_content = notes_file.read_text()\n   424→        assert \"Test note for persistence\" in notes_content\n   425→        \n   426→        # Verify project stats work across instances\n   427→        messages, words = services2['project'].get_project_stats(project_id)\n   428→        assert messages == 1\n   429→        assert words > 0\n   430→        \n   431→        print(\"State persistence test passed - all data survived service container restart\")\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
