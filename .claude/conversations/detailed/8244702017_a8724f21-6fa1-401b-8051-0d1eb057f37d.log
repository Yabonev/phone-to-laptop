    "content": "     1→\"\"\"\n     2→Audio generation utilities for transcription testing\n     3→\n     4→This module provides real audio file generation for testing the transcription\n     5→functionality without mocking the actual Whisper model behavior.\n     6→\"\"\"\n     7→import tempfile\n     8→import wave\n     9→import struct\n    10→import math\n    11→from pathlib import Path\n    12→from typing import Optional, Union\n    13→import logging\n    14→\n    15→logger = logging.getLogger(__name__)\n    16→\n    17→\n    18→class AudioGenerator:\n    19→    \"\"\"Generate real audio files for testing transcription functionality\"\"\"\n    20→    \n    21→    def __init__(self, sample_rate: int = 16000):\n    22→        \"\"\"\n    23→        Initialize audio generator\n    24→        \n    25→        Args:\n    26→            sample_rate: Sample rate for generated audio (Whisper prefers 16kHz)\n    27→        \"\"\"\n    28→        self.sample_rate = sample_rate\n    29→    \n    30→    def generate_silence(self, duration_seconds: float) -> bytes:\n    31→        \"\"\"Generate silent audio data\"\"\"\n    32→        num_samples = int(duration_seconds * self.sample_rate)\n    33→        return struct.pack('<' + 'h' * num_samples, *([0] * num_samples))\n    34→    \n    35→    def generate_tone(self, frequency: float, duration_seconds: float, amplitude: float = 0.3) -> bytes:\n    36→        \"\"\"\n    37→        Generate a pure tone\n    38→        \n    39→        Args:\n    40→            frequency: Frequency in Hz\n    41→            duration_seconds: Duration in seconds\n    42→            amplitude: Amplitude (0.0 to 1.0)\n    43→        \"\"\"\n    44→        num_samples = int(duration_seconds * self.sample_rate)\n    45→        samples = []\n    46→        \n    47→        for i in range(num_samples):\n    48→            # Generate sine wave\n    49→            t = i / self.sample_rate\n    50→            sample = amplitude * math.sin(2 * math.pi * frequency * t)\n    51→            # Convert to 16-bit integer\n    52→            sample_int = int(sample * 32767)\n    53→            samples.append(sample_int)\n    54→        \n    55→        return struct.pack('<' + 'h' * num_samples, *samples)\n    56→    \n    57→    def generate_speech_like_audio(self, duration_seconds: float) -> bytes:\n    58→        \"\"\"\n    59→        Generate speech-like audio with multiple frequencies\n    60→        This simulates human speech patterns for more realistic testing\n    61→        \"\"\"\n    62→        # Human speech fundamental frequencies: ~85-255 Hz (male), ~165-265 Hz (female)\n    63→        # Formant frequencies: ~500-1500 Hz for vowels\n    64→        \n    65→        num_samples = int(duration_seconds * self.sample_rate)\n    66→        samples = []\n    67→        \n    68→        # Create speech-like patterns\n    69→        fundamental_freq = 150  # Base frequency\n    70→        formant1 = 800  # First formant\n    71→        formant2 = 1200  # Second formant\n    72→        \n    73→        for i in range(num_samples):\n    74→            t = i / self.sample_rate\n    75→            \n    76→            # Add some variation to make it more speech-like\n    77→            freq_variation = 1.0 + 0.1 * math.sin(2 * math.pi * 5 * t)  # 5Hz variation\n    78→            \n    79→            # Combine fundamental and formants\n    80→            fundamental = 0.4 * math.sin(2 * math.pi * fundamental_freq * freq_variation * t)\n    81→            formant_1 = 0.2 * math.sin(2 * math.pi * formant1 * t)\n    82→            formant_2 = 0.1 * math.sin(2 * math.pi * formant2 * t)\n    83→            \n    84→            # Add envelope to simulate speech rhythm\n    85→            envelope = 0.5 + 0.5 * math.sin(2 * math.pi * 2 * t)  # 2Hz rhythm\n    86→            \n    87→            sample = envelope * (fundamental + formant_1 + formant_2)\n    88→            sample_int = int(sample * 16383)  # Slightly lower amplitude to avoid clipping\n    89→            samples.append(sample_int)\n    90→        \n    91→        return struct.pack('<' + 'h' * num_samples, *samples)\n    92→    \n    93→    def create_wav_file(self, audio_data: bytes, output_path: Union[str, Path]) -> Path:\n    94→        \"\"\"\n    95→        Create a WAV file from audio data\n    96→        \n    97→        Args:\n    98→            audio_data: Raw audio bytes\n    99→            output_path: Path where to save the file\n   100→            \n   101→        Returns:\n   102→            Path to the created file\n   103→        \"\"\"\n   104→        output_path = Path(output_path)\n   105→        output_path.parent.mkdir(parents=True, exist_ok=True)\n   106→        \n   107→        with wave.open(str(output_path), 'w') as wav_file:\n   108→            wav_file.setnchannels(1)  # Mono\n   109→            wav_file.setsampwidth(2)  # 16-bit\n   110→            wav_file.setframerate(self.sample_rate)\n   111→            wav_file.writeframes(audio_data)\n   112→        \n   113→        logger.info(f\"Created audio file: {output_path} ({len(audio_data)} bytes)\")\n   114→        return output_path\n   115→    \n   116→    def create_test_audio(self, test_type: str, duration: float = 3.0, \n   117→                         output_dir: Optional[Path] = None) -> Path:\n   118→        \"\"\"\n   119→        Create test audio files for different test scenarios\n   120→        \n   121→        Args:\n   122→            test_type: Type of test audio ('silence', 'tone', 'speech')\n   123→            duration: Duration in seconds\n   124→            output_dir: Directory to save file (uses temp if None)\n   125→            \n   126→        Returns:\n   127→            Path to created audio file\n   128→        \"\"\"\n   129→        if output_dir is None:\n   130→            output_dir = Path(tempfile.gettempdir())\n   131→        \n   132→        filename = f\"test_{test_type}_{duration}s.wav\"\n   133→        output_path = output_dir / filename\n   134→        \n   135→        if test_type == 'silence':\n   136→            audio_data = self.generate_silence(duration)\n   137→        elif test_type == 'tone':\n   138→            audio_data = self.generate_tone(440.0, duration)  # A4 note\n   139→        elif test_type == 'speech':\n   140→            audio_data = self.generate_speech_like_audio(duration)\n   141→        else:\n   142→            raise ValueError(f\"Unknown test type: {test_type}\")\n   143→        \n   144→        return self.create_wav_file(audio_data, output_path)\n   145→\n   146→\n   147→class TranscriptionTestData:\n   148→    \"\"\"Provides test data and utilities for transcription testing\"\"\"\n   149→    \n   150→    # Expected transcription results for known audio patterns\n   151→    EXPECTED_RESULTS = {\n   152→        'silence': \"\",  # Should transcribe to empty or very minimal\n   153→        'tone': \"\",     # Pure tones typically don't transcribe to meaningful text\n   154→        'speech': None, # Speech-like audio may produce some output but content is unpredictable\n   155→    }\n   156→    \n   157→    @classmethod\n   158→    def get_expected_result(cls, audio_type: str) -> Optional[str]:\n   159→        \"\"\"Get expected transcription result for a given audio type\"\"\"\n   160→        return cls.EXPECTED_RESULTS.get(audio_type)\n   161→    \n   162→    @classmethod\n   163→    def validate_transcription_output(cls, audio_type: str, transcribed_text: str) -> bool:\n   164→        \"\"\"\n   165→        Validate that transcription output matches expectations for audio type\n   166→        \n   167→        Args:\n   168→            audio_type: Type of audio that was transcribed\n   169→            transcribed_text: The transcription result\n   170→            \n   171→        Returns:\n   172→            True if result is as expected for this audio type\n   173→        \"\"\"\n   174→        transcribed_text = transcribed_text.strip()\n   175→        \n   176→        if audio_type in ['silence', 'tone']:\n   177→            # These should produce minimal or no text\n   178→            return len(transcribed_text) <= 10  # Allow for some model noise\n   179→        elif audio_type == 'speech':\n   180→            # Speech-like audio should produce some output but we can't predict exact content\n   181→            # We just verify it's not empty and has reasonable length\n   182→            return 0 <= len(transcribed_text) <= 500  # Reasonable bounds\n   183→        \n   184→        return False\n   185→\n   186→\n   187→def create_test_audio_files(output_dir: Path, durations: list[float] = None) -> dict[str, list[Path]]:\n   188→    \"\"\"\n   189→    Create a comprehensive set of test audio files\n   190→    \n   191→    Args:\n   192→        output_dir: Directory to store test files\n   193→        durations: List of durations to test (defaults to [1.0, 3.0, 5.0])\n   194→        \n   195→    Returns:\n   196→        Dict mapping audio types to lists of file paths\n   197→    \"\"\"\n   198→    if durations is None:\n   199→        durations = [1.0, 3.0, 5.0]\n   200→    \n   201→    output_dir.mkdir(parents=True, exist_ok=True)\n   202→    generator = AudioGenerator()\n   203→    \n   204→    audio_files = {\n   205→        'silence': [],\n   206→        'tone': [],\n   207→        'speech': []\n   208→    }\n   209→    \n   210→    for audio_type in audio_files.keys():\n   211→        for duration in durations:\n   212→            file_path = generator.create_test_audio(audio_type, duration, output_dir)\n   213→            audio_files[audio_type].append(file_path)\n   214→    \n   215→    logger.info(f\"Created {sum(len(files) for files in audio_files.values())} test audio files\")\n   216→    return audio_files\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing 