ly_text.call_args[0][0]\\n   187→        assert \\\"Created project\\\" in message\\n   188→        assert \\\"My Test Project\\\" in message\\n   189→\\n   190→\\n   191→class TestProjectsCommand:\\n   192→    \\\"\\\"\\\"Test projects listing command\\\"\\\"\\\"\\n   193→    \\n   194→    @pytest.mark.asyncio\\n   195→    async def test_list_no_projects(self):\\n   196→        \\\"\\\"\\\"Test listing when no projects\\\"\\\"\\\"\\n   197→        services = {\\n   198→            'state': Mock(),\\n   199→            'project': Mock(),\\n   200→            'transcription': Mock(),\\n   201→            'config': {}\\n   202→        }\\n   203→        services['state'].get_projects.return_value = {}\\n   204→        \\n   205→        command = ProjectsCommand(services)\\n   206→        \\n   207→        update = Mock()\\n   208→        update.message = Mock()\\n   209→        update.message.reply_text = AsyncMock()\\n   210→        context = Mock()\\n   211→        \\n   212→        await command.execute(update, context)\\n   213→        \\n   214→        # Should show no projects message\\n   215→        update.message.reply_text.assert_called_once()\\n   216→        assert \\\"No projects yet\\\" in update.message.reply_text.call_args[0][0]\\n   217→        \\n   218→    @pytest.mark.asyncio\\n   219→    async def test_list_with_projects(self):\\n   220→        \\\"\\\"\\\"Test listing projects with buttons\\\"\\\"\\\"\\n   221→        services = {\\n   222→            'state': Mock(),\\n   223→            'project': Mock(),\\n   224→            'transcription': Mock(),\\n   225→            'config': {}\\n   226→        }\\n   227→        services['state'].get_projects.return_value = {\\n   228→            \\\"001\\\": \\\"Project 1\\\",\\n   229→            \\\"002\\\": \\\"Project 2\\\"\\n   230→        }\\n   231→        \\n   232→        command = ProjectsCommand(services)\\n   233→        \\n   234→        update = Mock()\\n   235→        update.message = Mock()\\n   236→        update.message.reply_text = AsyncMock()\\n   237→        context = Mock()\\n   238→        \\n   239→        await command.execute(update, context)\\n   240→        \\n   241→        # Should show projects with keyboard\\n   242→        update.message.reply_text.assert_called_once()\\n   243→        call_args = update.message.reply_text.call_args\\n   244→        \\n   245→        assert \\\"Select or archive a project\\\" in call_args[0][0]\\n   246→        assert 'reply_markup' in call_args[1]\\n   247→        \\n   248→    @pytest.mark.asyncio\\n   249→    async def test_project_selection_callback(self, mock_services):\\n   250→        \\\"\\\"\\\"Test selecting project via button\\\"\\\"\\\"\\n   251→        services = mock_services\\n   252→        services['state'].get_projects.return_value = {\\\"001\\\": \\\"My Project\\\"}\\n   253→        \\n   254→        command = ProjectsCommand(services)\\n   255→        \\n   256→        query = Mock()\\n   257→        query.data = \\\"pick_001\\\"\\n   258→        query.answer = AsyncMock()\\n   259→        query.edit_message_text = AsyncMock()\\n   260→        \\n   261→        update = Mock()\\n   262→        update.callback_query = query\\n   263→        context = Mock()\\n   264→        \\n   265→        await command.handle_callback(update, context)\\n   266→        \\n   267→        # Verify project was selected\\n   268→        services['state'].set_active_project.assert_called_once_with(\\\"001\\\")\\n   269→        \\n   270→        # Verify response\\n   271→        query.answer.assert_called_once()\\n   272→        query.edit_message_text.assert_called_once()\\n   273→        assert \\\"Selected project\\\" in query.edit_message_text.call_args[0][0]\\n   274→\\n   275→\\n   276→class TestVoiceMessageHandler:\\n   277→    \\\"\\\"\\\"Test voice message processing\\\"\\\"\\\"\\n   278→    \\n   279→    @pytest.mark.asyncio\\n   280→    async def test_voice_no_project(self):\\n   281→    