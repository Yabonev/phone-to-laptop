 264→    \n   265→    @pytest.mark.integration\n   266→    @pytest.mark.asyncio\n   267→    async def test_project_archival_real_filesystem(self, real_services):\n   268→        \"\"\"Test project archival with real file operations\"\"\"\n   269→        services = real_services.get_all()\n   270→        \n   271→        # Create and populate a real project\n   272→        project_id = services['project'].create_project(\"Project to Archive\", {})\n   273→        services['state'].add_project(project_id, \"Project to Archive\")\n   274→        \n   275→        # Add some content\n   276→        services['project'].add_note(project_id, \"This project will be archived\")\n   277→        \n   278→        # Verify project exists\n   279→        project_dir = services['project'].get_project_dir(project_id)\n   280→        assert project_dir.exists()\n   281→        \n   282→        command = ProjectsCommand(services)\n   283→        \n   284→        # Mock archival confirmation callback\n   285→        query = Mock()\n   286→        query.data = f\"confirm_del_{project_id}\"\n   287→        query.answer = AsyncMock()\n   288→        query.edit_message_text = AsyncMock()\n   289→        \n   290→        update = Mock()\n   291→        update.callback_query = query\n   292→        context = Mock()\n   293→        \n   294→        # Execute archival\n   295→        await command.handle_callback(update, context)\n   296→        \n   297→        # Verify project directory was actually moved/deleted\n   298→        assert not project_dir.exists()\n   299→        \n   300→        # Verify archive directory exists\n   301→        projects_dir = Path(services['config']['projects_dir'])\n   302→        archive_dir = projects_dir.parent / \"archive\"\n   303→        assert archive_dir.exists()\n   304→        \n   305→        # Verify project was archived\n   306→        archived_projects = list(archive_dir.glob(f\"project-{project_id}-*\"))\n   307→        assert len(archived_proje