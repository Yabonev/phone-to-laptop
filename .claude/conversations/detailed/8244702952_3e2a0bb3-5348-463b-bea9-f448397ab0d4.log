l_transcription_service\n    83→        \n    84→        # Create 3 seconds of 440Hz tone (A4 note)\n    85→        tone_data = audio_generator.generate_tone(440.0, 3.0)\n    86→        audio_file = audio_generator.create_wav_file(tone_data, temp_dir / \"tone.wav\")\n    87→        \n    88→        try:\n    89→            # Transcribe the tone\n    90→            text, language = await service.transcribe_audio(audio_file, \"en\")\n    91→            \n    92→            # Pure tones should not transcribe to meaningful text\n    93→            assert TranscriptionTestData.validate_transcription_output('tone', text)\n    94→            assert language == \"en\"\n    95→            \n    96→            print(f\"Tone transcription result: '{text}' (length: {len(text)})\")\n    97→            \n    98→        finally:\n    99→            if audio_file.exists():\n   100→                audio_file.unlink()\n   101→    \n   102→    @pytest.mark.transcription\n   103→    @pytest.mark.slow\n   104→    @pytest.mark.asyncio\n   105→    async def test_transcribe_speech_like_audio(self, real_transcription_service, audio_generator, temp_dir):\n   106→        \"\"\"Test that speech-like audio produces some transcription output\"\"\"\n   107→        service = real_transcription_service\n   108→        \n   109→        # Create 4 seconds of speech-like audio\n   110→        speech_data = audio_generator.generate_speech_like_audio(4.0)\n   111→        audio_file = audio_generator.create_wav_file(speech_data, temp_dir / \"speech.wav\")\n   112→        \n   113→        try:\n   114→            # Transcribe the speech-like audio\n   115→            text, language = await service.transcribe_audio(audio_file, \"en\")\n   116→            \n   117→            # Speech-like audio may produce some output\n   118→            assert TranscriptionTestData.validate_transcription_output('speech', text)\n   119→            assert language == \"en\"\n   120→            \n   121→            print(f\"