  try:\n   162→            # Verify file properties\n   163→            assert temp_file.exists()\n   164→            assert temp_file.suffix == '.ogg'\n   165→            assert temp_file.parent == service.audio_dir\n   166→            \n   167→            # Verify we can write to it\n   168→            temp_file.write_bytes(b'test data')\n   169→            assert temp_file.read_bytes() == b'test data'\n   170→            \n   171→        finally:\n   172→            # Cleanup\n   173→            if temp_file.exists():\n   174→                temp_file.unlink()\n   175→    \n   176→    @pytest.mark.transcription\n   177→    def test_audio_file_cleanup(self, real_transcription_service, temp_dir):\n   178→        \"\"\"Test that audio file cleanup actually deletes files\"\"\"\n   179→        service = real_transcription_service\n   180→        \n   181→        # Create test file\n   182→        test_file = temp_dir / \"test_cleanup.ogg\"\n   183→        test_file.write_bytes(b'test audio data')\n   184→        assert test_file.exists()\n   185→        \n   186→        # Cleanup file\n   187→        service.cleanup_audio_file(test_file)\n   188→        \n   189→        # Verify file was deleted\n   190→        assert not test_file.exists()\n   191→        \n   192→        # Cleanup non-existent file should not error\n   193→        service.cleanup_audio_file(test_file)  # Should not raise\n   194→    \n   195→    @pytest.mark.transcription\n   196→    @pytest.mark.asyncio\n   197→    async def test_transcription_with_nonexistent_file_raises_error(self, real_transcription_service, temp_dir):\n   198→        \"\"\"Test that transcribing non-existent file raises appropriate error\"\"\"\n   199→        service = real_transcription_service\n   200→        \n   201→        nonexistent_file = temp_dir / \"does_not_exist.wav\"\n   202→        assert not nonexistent_file.exists()\n   203→        \n   204→        # Should raise an exception when trying to transcribe non-existent file\n   205→        with pytest.raises(Exception):  # Could be FileNotFoundError or other Whisper error\n   206→            await service.transcribe_audio(nonexistent_file, \"en\")\n   207→    \n   208→    @pytest.mark.transcription\n   209→    @pytest.mark.asyncio\n   210→    async def test_transcription_with_invalid_language_code(self, real_transcription_service, audio_generator, temp_dir):\n   211→        \"\"\"Test transcription behavior with invalid language codes\"\"\"\n   212→        service = real_transcription_service\n   213→        \n   214→        # Create valid audio\n   215→        silence_data = audio_generator.generate_silence(1.0)\n   216→        audio_file = audio_generator.create_wav_file(silence_data, temp_dir / \"test.wav\")\n   217→        \n   218→        try:\n   219→            # Test with invalid language code\n   220→            # Whisper should handle this gracefully or raise specific error\n   221→            text, language = await service.transcribe_audio(audio_file, \"invalid_lang\")\n   222→            \n   223→            # Should either work (Whisper fallback) or raise exception\n   224→            # The key is that it should be consistent and not crash unexpectedly\n   225→            assert isinstance(text, str)\n   226→            assert isinstance(language, str)\n   227→            \n   228→        except Exception as e:\n   229→            # If it raises an exception, it should be a sensible one\n   230→            assert \"language\" in str(e).lower() or \"invalid\" in str(e).lower()\n   231→            \n   232→        finally:\n   233→            if audio_file.exists():\n   234→                audio_file.unlink()\n   235→\n   236→\n   237→class TestTranscriptionPerformance:\n   238→    \"\"\"Performance tests for transcription functionality\"\"\"\n   239→    \n   240→    @pytest.mark.performance\n   241→    @pytest.mark.slow\n   242→    @pytest.mark.asyncio\n   243→    async def test_transcription_performance_benchmarks(self, real_transcription_service, test_audio_files, performance_timer):\n   244→        \"\"\"Benchmark transcription performance with different audio types and durations\"\"\"\n   245→        service = real_transcription_service\n   246→        \n   247→        results = {}\n   248→        \n   249→        for audio_type, files in test_audio_files.items():\n   250→            type_results = []\n   251→            \n   252→            for audio_file in files:\n   253→                # Time the transcription\n   254→                performance_timer.start()\n   255→                text, language = await service.transcribe_audio(audio_file, \"en\")\n   256→                duration = performance_timer.stop()\n   257→                \n   258→                type_results.append({\n   259→                    'file': audio_file.name,\n   260→                    'duration': duration,\n   261→                    'text_length': len(text),\n   262→                    'text_preview': text[:50] + '...' if len(text) > 50 else text\n   263→                })\n   264→            \n   265→            results[audio_type] = type_results\n   266→        \n   267→        # Log performance results\n   268→        print(\"\\n=== Transcription Performance Results ===\")\n   269→        for audio_type, type_results in results.items():\n   270→            print(f\"\\n{audio_type.upper()} Audio:\")\n   271→            for result in type_results:\n   272→                print(f\"  {result['file']}: {result['duration']:.2f}s -> {result['text_length']} chars\")\n   273→                if result['text_preview'].strip():\n   274→                    print(f\"    Preview: '{result['text_preview']}'\")\n   275→        \n   276→        # Performance assertions\n   277→        for audio_type, type_results in results.items():\n   278→            for result in type_results:\n   279→                # Transcription should complete in reasonable time (adjust based on your hardware)\n   280→                a