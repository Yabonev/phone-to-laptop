scription for integration testing\", language\n   350→        \n   351→        services['transcription'].transcribe_audio = mock_transcribe\n   352→        \n   353→        try:\n   354→            # Execute voice handling\n   355→            await handler.handle_voice(update, context)\n   356→            \n   357→            # Verify message was marked as processed\n   358→            assert services['state'].is_message_processed(\"12345\")\n   359→            \n   360→            # Verify note was added to project\n   361→            project_dir = services['project'].get_project_dir(project_id)\n   362→            notes_file = project_dir / \"notes.md\"\n   363→            notes_content = notes_file.read_text()\n   364→            \n   365→            assert \"This is a mocked transcription for integration testing\" in notes_content\n   366→            \n   367→            # Verify confirmation message\n   368→            processing_msg.edit_text.assert_called_once()\n   369→            confirmation_text = processing_msg.edit_text.call_args[0][0]\n   370→            assert \"Added to project\" in confirmation_text\n   371→            assert \"Voice Test Project\" in confirmation_text\n   372→            \n   373→        finally:\n   374→            # Restore original transcription method\n   375→            services['transcription'].transcribe_audio = original_transcribe\n   376→    \n   377→    @pytest.mark.integration\n   378→    @pytest.mark.asyncio\n   379→    async def test_voice_no_active_project_error(self, real_services):\n   380→        \"\"\"Test voice handling error when no project selected\"\"\"\n   381→        services = real_services.get_all()\n   382→        \n   383→        # Ensure no active project\n   384→        assert services['state'].get_active_project() is None\n   385→        \n   386→        handler = VoiceMessageHandler(services)\n   387→        \n   388→        update = Mock()\n   389→        update.message = Mock()\n   390→        upda