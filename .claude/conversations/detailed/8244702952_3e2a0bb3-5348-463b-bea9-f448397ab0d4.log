  command = ProjectsCommand(mock_services)\n    95→        \n    96→        # Setup delete request\n    97→        query = Mock()\n    98→        query.data = \"del_001\"\n    99→        query.answer = AsyncMock()\n   100→        query.edit_message_text = AsyncMock()\n   101→        \n   102→        update = Mock()\n   103→        update.callback_query = query\n   104→        context = Mock()\n   105→        \n   106→        # Execute\n   107→        await command.handle_callback(update, context)\n   108→        \n   109→        # Should show confirmation dialog\n   110→        query.edit_message_text.assert_called_once()\n   111→        call_args = query.edit_message_text.call_args\n   112→        assert \"Archive project\" in call_args[0][0]\n   113→        assert \"Test Project\" in call_args[0][0]\n   114→        \n   115→    @pytest.mark.asyncio\n   116→    async def test_invalid_project_selection(self, mock_services):\n   117→        \"\"\"Test selecting non-existent project\"\"\"\n   118→        mock_services['state'].get_projects.return_value = {}\n   119→        command = ProjectsCommand(mock_services)\n   120→        \n   121→        query = Mock()\n   122→        query.data = \"pick_999\"\n   123→        query.answer = AsyncMock()\n   124→        query.edit_message_text = AsyncMock()\n   125→        \n   126→        update = Mock()\n   127→        update.callback_query = query\n   128→        context = Mock()\n   129→        \n   130→        await command.handle_callback(update, context)\n   131→        \n   132→        # Should show error\n   133→        query.edit_message_text.assert_called_once()\n   134→        assert \"not found\" in query.edit_message_text.call_args[0][0]\n   135→\n   136→\n   137→class TestVoiceHandlerFull:\n   138→    \"\"\"Test additional voice handler functionality\"\"\"\n   139→    \n   140→    @pytest.mark.asyncio\n   141→    async def test_voice_with_project_not_found(self, mock_services):\n   142→        \"\"\"Test voice when project exists in state but not on disk\"\"\"\n   143→        mock_services['state'].get_active_project.return_value = \"001\"\n   144→        mock_services['state'].get_projects.return_value = {}  # No projects\n   145→        mock_services['state'].is_message_processed.return_value = False\n   146→        \n   147→        handler = VoiceMessageHandler(mock_services)\n   148→        \n   149→        update = Mock()\n   150→        update.message = Mock()\n   151→        update.message.message_id = 123\n   152→        update.message.reply_text = AsyncMock()\n   153→        context = Mock()\n   154→        \n   155→        await handler.handle_voice(update, context)\n   156→        \n   157→        # Should show error\n   158→        update.message.reply_text.assert_called_once()\n   159→        assert \"Project not found\" in update.message.reply_text.call_args[0][0]\n   160→        \n   161→    @pytest.mark.asyncio\n   162→    async def test_voice_processing_success(self, mock_services, temp_dir):\n   163→        \"\"\"Test successful voice processing\"\"\"\n   164→        # Setup mocks\n   165→        mock_services['state'].get_active_project.return_value = \"001\"\n   166→        mock_services['state'].get_projects.return_value = {\"001\": \"Test Project\"}\n   167→        mock_services['state'].is_message_processed.return_value = False\n   168→        mock_services['state'].get_language.return_value = \"en\"\n   169→        \n   170→        # Mock transcription\n   171→        mock_services['transcription'].create_temp_audio_file.return_value = temp_dir / \"test.ogg\"\n   172→        mock_services['transcription'].transcribe_audio = AsyncMock(\n   173→            return_value=(\"This is a test\", \"en\")\n   174→        )\n   175→        mock_services['transcription'].cleanup_audio_file = Mock()\n   176→        \n   177→        # Mock project service\n   178→        mock_services['project'].add_note.return_value = True\n   179→        \n   180→        handler = VoiceMessageHandler(mock_services)\n   181→        \n   182→        # Create mock update\n   183→        voice_file = Mock()\n   184→        voice_file.get_file = AsyncMock()\n   185→        voice_file.get_file.return_value.download_to_drive = AsyncMock()\n   186→        \n   187→        update = Mock()\n   188→        update.message = Mock()\n   189→        update.message.message_id = 123\n   190→        update.message.voice = voice_file\n   191→        update.message.reply_text = AsyncMock()\n   192→        \n   193→        # Create mock processing message\n   194→        processing_msg = Mock()\n   195→        processing_msg.edit_text = AsyncMock()\n   196→        update.message.reply_text.return_value = processing_msg\n   197→        \n   198→        context = Mock()\n   199→        \n   200→        # Execute\n   201→        await handler.handle_voice(update, context)\n   202→        \n   203→        # Verify transcription happened\n   204→        mock_services['transcription'].transcribe_audio.assert_called_once()\n   205→        \n   206→        # Verify note was added\n   207→        mock_services['project'].add_note.assert_called_once_with(\n   208→            \"001\", \"This is a test\", None\n   209→        )\n   210→        \n   211→        # Verify message marked as processed\n   212→        mock_services['state'].mark_message_processed.assert_called_once_with(\"123\")\n   213→        \n   214→    @pytest.mark.asyncio\n   215→    async def test_voice_with_bulgarian_translation(self, mock_services, temp_dir):\n   216→        \"\"\"Test voice processing with Bulgarian translation\"\"\"\n   217→        mock_services['state'].get_active_project.return_value = \"001\"\n   218→        mock_services['state'].get_projects.return_value = {\"001\": \"Test Project\"}\n   219→        mock_services['state'].is_message_processed.return_value = False\n   220→        mock_services['state'].get_language.return_value = \"bg\"\n   221→        \n   222→        # Mock transcription\n   223→        audio_path = temp_dir / \"test.ogg\"\n   224→        audio_path.touch()\n   225→        mock_services['transcription'].create_temp_audio_file.return_value = audio_path\n   226→        mock_services['transcription'].transcribe_audio = AsyncMock(\n   227→            return_value=(\"Това е тест\", \"bg\")\n   228→        )\n   229→        mock_services['transcription'].translate_to_english = AsyncMock(\n   230→            return_value=\"This is a test\"\n   231→        )\n   232→        mock_services['transcription'].cleanup_audio_file = Mock()\n   233→        \n   234→        handler = VoiceMessageHandler(mock_services)\n   235→        \n   236→        # Create mock update\n   237→        voice_file = Mock()\n   238→        voice_file.get_file = AsyncMock()\n   239→        voice_file.get_file.return_value.download_to_drive = AsyncMock()\n   240→        \n   241→        update = Mock()\n   242→        update.message = Mock()\n   243→        update.message.message_id = 123\n   244→        update.message.voice = voice_file\n   245→        update.message.reply_text = AsyncMock()\n   246→        \n   247→        processing_msg = Mock()\n   248→        processing_msg.edit_text = AsyncMock()\n   249→        update.message.reply_text.return_value = processing_msg\n   250→        \n   251→        context = Mock()\n   252→        \n   253→        # Execute\n   254→        await handler.handle_voice(update, context)\n   255→        \n   256→        # Verify translation was called\n   257→        mock_services['transcription'].translate_to_english.assert_called_once()\n   258→        \n   259→        # Verify note added with translation\n   260→        mock_services['project'].add_note.assert_called_once_with(\n   261→            \"001\", \"Това е тест\", \"This is a test\"\n   262→        )\n   263→        \n   264→    @pytest.mark.asyncio\n   265→    async def test_voice_processing_error(self, mock_services):\n   266→        \"\"\"Test voice processing