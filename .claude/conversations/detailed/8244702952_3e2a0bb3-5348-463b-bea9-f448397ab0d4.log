2→    @patch('src.services.transcription.whisper.load_model')\n   313→    def test_lazy_model_loading(self, mock_load_model, temp_dir):\n   314→        \"\"\"Test that model loads lazily\"\"\"\n   315→        mock_model = Mock()\n   316→        mock_load_model.return_value = mock_model\n   317→        \n   318→        service = TranscriptionService(\"tiny\", temp_dir / \"audio\")\n   319→        assert service.model is None\n   320→        \n   321→        # Trigger load\n   322→        service._load_model()\n   323→        assert service.model == mock_model\n   324→        mock_load_model.assert_called_once_with(\"tiny\")\n   325→        \n   326→        # Second call shouldn't reload\n   327→        service._load_model()\n   328→        mock_load_model.assert_called_once()  # Still only once\n   329→        \n   330→    @pytest.mark.asyncio\n   331→    @patch('src.services.transcription.whisper.load_model')\n   332→    async def test_transcribe_audio(self, mock_load_model, temp_dir):\n   333→        \"\"\"Test audio transcription\"\"\"\n   334→        # Setup mock model\n   335→        mock_model = Mock()\n   336→        mock_model.transcribe.return_value = {\n   337→            \"text\": \" Test transcription \",\n   338→            \"language\": \"en\"\n   339→        }\n   340→        mock_load_model.return_value = mock_model\n   341→        \n   342→        service = TranscriptionService(\"tiny\", temp_dir / \"audio\")\n   343→        \n   344→        # Create test audio file\n   345→        audio_file = temp_dir / \"test.ogg\"\n   346→        audio_file.touch()\n   347→        \n   348→        # Transcribe\n   349→        text, lang = await service.transcribe_audio(audio_file, \"en\")\n   350→        \n   351→        assert text == \"Test transcription\"  # Stripped\n   352→        assert lang == \"en\"\n   353→        mock_model.transcribe.assert_called_once()\n   354→        \n   355→    @pytest.mark.asyncio\n   356→    @patch('src.services.transcription.whisper.load_model')\n   357→    async def test_translate_to_english(self, mock_load_model, temp_dir):\n   358→        \"\"\"Test translation to English\"\"\"\n   359→        mock_model = Mock()\n   360→        mock_model.transcribe.return_value = {\n   361→            \"text\": \" English translation \"\n   362→        }\n   363→        mock_load_model.return_value = mock_model\n   364→        \n   365→        service = TranscriptionService(\"tiny\", temp_dir / \"audio\")\n   366→        \n   367→        audio_file = temp_dir / \"test.ogg\"\n   368→        audio_file.touch()\n   369→        \n   370→        # Translate\n   371→        translation = await service.translate_to_english(audio_file, \"bg\")\n   372→        \n   373→        assert translation == \"English translation\"\n   374→        # Check task parameter was set\n   375→        call_args = mock_model.transcribe.call_args\n   376→        assert call_args[1][\"task\"] == \"translate\"\n   377→        assert call_args[1][\"language\"] == \"bg\"\n   378→        \n   379→    def test_create_temp_audio_file(self, temp_dir):\n   380→        \"\"\"Test temporary audio file creation\"\"\"\n   381→        service = TranscriptionService(\"tiny\", temp_dir / \"audio\")\n   382→        \n   383→        temp_file = service.create_temp_audio_file(\".ogg\")\n   384→        \n   385→        assert temp_file.exists()\n   386→        assert temp_file.suffix == \".ogg\"\n   387→        assert temp_file.parent == temp_dir / \"audio\"\n   388→        \n   389→        # Cleanup\n   390→        temp_file.unlink()\n   391→        \n   392→    def test_cleanup_audio_file(self, temp_dir):\n   393→        \"\"\"Test audio file cleanup\"\"\"\n   394→        service = TranscriptionService(\"tiny\", temp_dir / \"audio\")\n   395→        \n   396→        # Create test file\n   397→        test_file = temp_dir / \"audio\" / \"test.ogg\"\n   398→        test_file.touch()\n   399→        assert test_file.exists()\n   400→        \n   401→        # Cleanup\n   402→        service.cleanup_audio_file(test_file)\n   403→        assert not test_file.exists()\n   404→        \n   405→        # Cleanup non-existent file shouldn't error\n   406→        service.cleanup_audio_file(test_file)  # Should not raise\n   407→\n   408→\n   409→class TestBotQueueProcessing:\n   410→    \"\"\"Test bot queue processing\"\"\"\n   411→    \n   412→    @pytest.mark.asyncio\n   413→    async def test_process_queued_voice_messages(self, test_config):\n   414→        \"\"\"Test processing queued voice messages\"\"\"\n   415→        bot = VoiceNotesBot(test_config)\n   416→        \n   417→        # Register voice handler\n   418→        bot.register_command(VoiceMessageHandler)\n   419→        \n   420→        # Mock voice update\n   421→        voice_update = Mock()\n   422→        voice_update.update_id = 100\n   423→        voice_update.message = Mock()\n   424→        voice_update.message.voice = Mock()\n   425→        voice_update.message.text = None\n   426→        voice_update.callback_query = None\n   427→        \n   428→        # Mock application\n   429→        app = Mock()\n   430→        app.bot = Mock()\n   431→        app.bot.get_updates = AsyncMock(return_value=[voice_update])\n   432→        \n   433→        # Mock voice handler\n   434→        with patch.object(bot.registry.voice_handler, 'handle_voice', new_callable=AsyncMock):\n   435→            await bot.process_queued_messages(app)\n   436→            \n   437→            # Should process voice message\n   438→            bot.registry.voice_handler.handle_voice.assert_called_once()\n   439→            \n   440→    @pytest.mark.asyncio\n   441→    async def test_process_queued_text_commands(self, test_config):\n   442→        \"\"\"Test processing queued text commands\"\"\"\n   443→        bot = VoiceNotesBot(test_config)\n   444→        \n   445→        # Register start command\n   446→        from src.commands.start import StartCommand\n   447→        bot.register_command(StartCommand)\n   448→        \n   449→        # Mock text update\n   450→        text_update = Mock()\n   451→        text_update.update_id = 100\n   452→        text_update.message = Mock()\n   453→        text_update.message.voice = None\n   454→        text_update.message.text = \"/start\"\n   455→        text_update.callback_query = None\n   456→        \n   457→        # Mock application\n   458→        app = Mock()\n   459→        app.bot = Mock()\n   460→        app.bot.get_updates = AsyncMock(return_value=[text_update])\n   461→        \n   462→        # Mock command execution\n   463→        start_cmd = bot.registry.get_command(\"start\")\n   464→        with patch.object(start_cmd, 'execute', new_callable=AsyncMock):\n   465→            await bot.process_queued_messages(app)\n   466→            \n   467→            # Should execute start command\n   468→            start_cmd.execute.assert_called_once()\n   469→            \n   470→    @pytest.mark.asyncio\n   471→    async def test_process_queued_with_error(self, test_config):\n   472→        \"\"\"Test queue processing with error\"\"\"\n   473→        bot = VoiceNotesBot(test_config)\n   474→        \n   475→        # Mock application with error\n   476→        app = Mock()\n   477→        app.bot = Mock()\n   478→        app.bot.get_updates = AsyncMock(side_effect=Exception(\"Network error\"))\n   479→        \n   480→        # Should handle error gracefully\n   481→        await bot.process_queued_messages(app)\n   482→        # Should not raise\n   483→\n   484→\n   485→class TestCommandProperties:\n   486→    \"\"\"Test command property coverage\"\"\"\n   487→    \n   488→    def test_command_properties(self):\n   489→        \"\"\"Test all command properties\"\"\"\n   490→        from src.commands.start import StartCommand\n   491→        from src.commands.status import StatusCommand\n   492→        from src.commands.new_project import NewProjectCommand\n   493→        from s