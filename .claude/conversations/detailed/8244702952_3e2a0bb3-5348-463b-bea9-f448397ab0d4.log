    "content": "     1→\"\"\"\n     2→REAL transcription tests using actual Whisper models and audio files\n     3→\n     4→These tests replace the mock-abusing transcription tests with real functionality validation.\n     5→We use actual Whisper models and generated audio to verify transcription actually works.\n     6→\"\"\"\n     7→import pytest\n     8→import tempfile\n     9→from pathlib import Path\n    10→import time\n    11→import asyncio\n    12→\n    13→from src.services.transcription import TranscriptionService\n    14→from tests.audio_helpers import AudioGenerator, TranscriptionTestData\n    15→\n    16→\n    17→class TestRealTranscriptionService:\n    18→    \"\"\"Test transcription service with REAL Whisper models and audio\"\"\"\n    19→    \n    20→    @pytest.mark.transcription\n    21→    def test_service_initialization_creates_audio_dir(self, temp_dir):\n    22→        \"\"\"Test that service properly initializes and creates directories\"\"\"\n    23→        audio_dir = temp_dir / \"audio\"\n    24→        service = TranscriptionService(model_name=\"tiny\", audio_dir=audio_dir)\n    25→        \n    26→        # Verify properties set correctly\n    27→        assert service.model_name == \"tiny\"\n    28→        assert service.audio_dir == audio_dir\n    29→        assert service.model is None  # Lazy loading\n    30→        \n    31→        # Verify directory was created\n    32→        assert audio_dir.exists()\n    33→        assert audio_dir.is_dir()\n    34→    \n    35→    @pytest.mark.transcription\n    36→    def test_model_loading_actually_loads_whisper(self, real_transcription_service):\n    37→        \"\"\"Test that model loading actually loads a real Whisper model\"\"\"\n    38→        service = real_transcription_service\n    39→        \n    40→        # Model should be None initially (or pre-loaded in fixture)\n    41→        # Load it if not already loaded\n    42→        if service.model is None:\n    43→            service._load_model()\n    44→        \n    45→        # Verify we have a real Whisper model\n    46→        assert service.model is not None\n    47→        assert hasattr(service.model, 'transcribe')\n    48→        assert callable(service.model.transcribe)\n    49→    \n    50→    @pytest.mark.transcription\n    51→    @pytest.mark.slow\n    52→    @pytest.mark.asyncio\n    53→    async def test_transcribe_silence_produces_minimal_output(self, real_transcription_service, audio_generator, temp_dir):\n    54→        \"\"\"Test that silent audio produces minimal or no transcription\"\"\"\n    55→        service = real_transcription_service\n    56→        \n    57→        # Create 2 seconds of silence\n    58→        silence_data = audio_generator.generate_silence(2.0)\n    59→        audio_file = audio_generator.create_wav_file(silence_data, temp_dir / \"silence.wav\")\n    60→        \n    61→        try:\n    62→            # Transcribe the silence\n    63→            text, language = await service.transcribe_audio(audio_file, \"en\")\n    64→            \n    65→            # Silence should produce minimal text (Whisper may output some noise)\n    66→            assert TranscriptionTestData.validate_transcription_output('silence', text)\n    67→            assert language == \"en\"\n    68→            \n    69→            # Log what was actually transcribed for debugging\n    70→            print(f\"Silence transcription result: '{text}' (length: {len(text)})\")\n    71→            \n    72→        finally:\n    73→            # Cleanup\n    74→            if audio_file.exists():\n    75→                audio_file.unlink()\n    76→    \n    77→    @pytest.mark.transcription\n    78→    @pytest.mark.slow\n    79→    @pytest.mark.asyncio\n    80→    async def test_transcribe_tone_produces_minimal_output(self, real_transcription_service, audio_generator, temp_dir):\n    81→        \"\"\"Test that pure tone audio produces minimal transcription\"\"\"\n    82→        service = real_transcription_service\n    83→        \n    84→        # Create 3 seconds of 440Hz tone (A4 note)\n    85→        tone_data = audio_generator.generate_tone(440.0, 3.0)\n    86→        audio_file = audio_generator.create_wav_file(tone_data, temp_dir / \"tone.wav\")\n    87→        \n    88→        try:\n    89→            # Transcribe the tone\n    90→            text, language = await service.transcribe_audio(audio_file, \"en\")\n    91→            \n    92→            # Pure tones should not transcribe to meaningful text\n    93→            assert TranscriptionTestData.validate_transcription_output('tone', text)\n    94→            assert language == \"en\"\n    95→            \n    96→            print(f\"Tone transcription result: '{text}' (length: {len(text)})\")\n    97→            \n    98→        finally:\n    99→            if audio_file.exists():\n   100→                audio_file.unlink()\n   101→    \n   102→    @pytest.mark.transcription\n   103→    @pytest.mark.slow\n   104→    @pytest.mark.asyncio\n   105→    async def test_transcribe_speech_like_audio(self, real_transcription_service, audio_generator, temp_dir):\n   106→        \"\"\"Test that speech-like audio produces some transcription output\"\"\"\n   107→        service = real_transcription_service\n   108→        \n   109→        # Create 4 seconds of speech-like audio\n   110→        speech_data = audio_generator.generate_speech_like_audio(4.0)\n   111→        audio_file = audio_generator.create_wav_file(speech_data, temp_dir / \"speech.wav\")\n   112→        \n   113→        try:\n   114→            # Transcribe the speech-like audio\n   115→            text, language = await service.transcribe_audio(audio_file, \"en\")\n   116→            \n   117→            # Speech-like audio may produce some output\n   118→            assert TranscriptionTestData.validate_transcription_output('speech', text)\n   119→            assert language == \"en\"\n   120→            \n   121→            print(f\"Speech-like transcription result: '{text}' (length: {len(text)})\")\n   122→            \n   123→        finally:\n   124→            if audio_file.exists():\n   125→                audio_file.unlink()\n   126→    \n   127→    @pytest.mark.transcription\n   128→    @pytest.mark.slow\n   129→    @pytest.mark.asyncio\n   130→    async def test_translation_to_english_with_bulgarian_language(self, real_transcription_service, audio_generator, temp_dir):\n   131→        \"\"\"Test Bulgarian to English translation functionality\"\"\"\n   132→        service = real_transcription_service\n   133→        \n   134→        # Create test audio (speech-like for Bulgarian)\n   135→        speech_data = audio_generator.generate_speech_like_audio(3.0)\n   136→        audio_file = audio_generator.create_wav_file(speech_data, temp_dir / \"bulgarian.wav\")\n   137→        \n   138→        try:\n   139→            # Test translation function\n   140→            translation = await service.translate_to_english(audio_file, \"bg\")\n   141→            \n   142→            # Should return a string (even if empty or minimal for generated audio)\n   143→            assert isinstance(translation, str)\n   144→            # Translation should be reasonable length (not massive)\n   145→            assert len(translation) <= 500\n   146→            \n   147→            print(f\"Bulgarian translation result: '{translation}' (length: {len(translation)})\")\n   148→            \n   149→        finally:\n   150→            if audio_file.exists():\n   151→                audio_file.unlink()\n   152→    \n   153→    @pytest.mark.transcription\n   154→    def test_temp_audio_file_creation(self, real_transcription_service):\n   155→        \"\"\"Test that temporary audio files are created correctly\"\"\"\n   156→        service = real_transcription_service\n   157→        \n   158→        # Create temp file\n   159→        temp_file = service.create_temp_audio_file('.ogg')\n   160→        \n   161→        try:\n   162→            # Verify file properties\n   163→            assert temp_file.exists()\n   164→            assert temp_file.suffix == '.ogg'\n   165→            assert temp_file.parent == service.audio_dir\n   166→            \n   167→            # Verify we can write to it\n   168→            temp_file.write_bytes(b'test data')\n   169→            assert temp_file.read_bytes() == b'test data'\n   170→            \n   171→        finally:\n   172→            # Cleanup\n   173→            if temp_file.exists():\n   174→                temp_file.unlink()\n   175→    \n   176→    @pytest.mark.transcription\n   177→    def test_audio_file_cleanup(self, real_transcription_service, temp_dir):\n   178→        \"\"\"Test that audio file cleanup actually deletes files\"\"\"\n   179→        service = real_transcription_service\n   180→        \n   181→        # Create test file\n   182→        test_file = temp_dir / \"test_cleanup.ogg\"\n   183→        test_file.write_bytes(b'test audio data')\n   184→        assert test_file.exists()\n   185→        \n   186→        # Cleanup file\n   187→        service.cleanup_audio_file(test_file)\n   188→        \n   189→        # Verify file was deleted\n   190→        assert not test_file.exists()\n   191→        \n   192→        # Cleanup non-existent file should not error\n   193→        service.cleanup_audio_file(test_file)  # Should not raise\n   194→    \n   195→    @pytest.mark.transcription\n   196→    @pytest.mark.asyncio\n   197→    async def test_transcription_with_nonexistent_file_raises_error(self, real_transcription_service, temp_dir):\n   198→        \"\"\"Test that transcribing non-existent file raises appropriate error\"\"\"\n   199→        service = real_transcription_service\n   200→        \n   201→        nonexistent_file = temp_dir / \"does_not_exist.wav\"\n   202→        assert not nonexistent_file.exists()\n   203→        \n   204→        # Should raise an exception when trying to transcribe non-existent file\n   205→        with pytest.raises(Exception):  # Could be FileNotFoundError or other Whisper error\n   206→            await service.transcribe_audio(nonexistent_file, \"en\")\n   207→    \n   208→    @pytest.mark.transcription\n   209→    @pytest.mark.asyncio\n   210→    async def test_transcription_with_invalid_language_code(self, real_transcription_service, audio_generator, temp_dir):\n   211→        \"\"\"Test transcription behavior with invalid language codes\"\"\"\n   212→        service = real_transcription_service\n   213→        \n   214→        # Create valid audio\n   215→        silence_data = audio_generator.generate_silence(1.0)\n   216→        audio_file = audio_generator.create_wav_file(silence_data, temp_dir / \"test.wav\")\n   217→        \n   218→        try:\n   219→            # Test with invalid language code\n   220→            # Whisper should handle this gracefully or raise specific error\n   221→            text, language = await service.transcribe_audio(audio_file, \"invalid_lang\")\n   222→            \n   223→            # Should either work (Whisper fallback) or raise exception\n   224→            # The key is that it should be consistent and not crash unexpectedly\n   225→            assert isinstance(text, str)\n   226→            assert isinstance(language, str)\n   227→            \n   228→        except Exception as e:\n   229→            # If it raises an exception, it should be a sensible one\n   230→            assert \"language\" in str(e).lower() or \"invalid\" in str(e).lower()\n   231→            \n   232→        finally:\n   233→            if audio_file.exists():\n   234→                audio_file.unlink()\n   235→\n   236→\n   237→class TestTranscriptionPerformance:\n   238→    \"\"\"Performance tests for transcription functionality\"\"\"\n   239→    \n   240→    @pytest.mark.performance\n   241→    @pytest.mark.slow\n   242→    @pytest.mark.asyncio\n   243→    async def test_transcription_performance_benchmarks(self, real_transcription_service, test_audio_files, performance_timer):\n   244→        \"\"\"Benchmark transcription performance with different audio types and durations\"\"\"\n   245→        service = real_transcription_service\n   246→        \n   247→        results = {}\n   248→        \n   249→        for audio_type, files in test_audio_files.items():\n   250→            type_results = []\n   251→            \n   252→            for audio_file in files:\n   253→                # Time the transcription\n   254→                performance_timer.start()\n   255→                text, language = await service.transcribe_audio(audio_file, \"en\")\n   256→                duration = performance_timer.stop()\n   257→                \n   258→                type_results.append({\n   259→                    'file': audio_file.name,\n   260→                    'duration': duration,\n   261→                    'text_length': len(text),\n   262→                    'text_preview': text[:50] + '...' if len(text) > 50 else text\n   263→                })\n   264→            \n   265→            results[audio_type] = type_results\n   266→        \n   267→        # Log performance results\n   268→        print(\"\\n=== Transcription Performance Results ===\")\n   269→        for audio_type, type_results in results.items():\n   270→            print(f\"\\n{audio_type.upper()} Audio:\")\n   271→            for result in type_results:\n   272→                print(f\"  {result['file']}: {result['duration']:.2f}s -> {result['text_length']} chars\")\n   273→                if result['text_preview'].strip():\n   274→                    print(f\"    Preview: '{result['text_preview']}'\")\n   275→        \n   276→        # Performance assertions\n   277→        for audio_type, type_results in results.items():\n   278→            for result in type_results:\n   279→                # Transcription should complete in reasonable time (adjust based on your hardware)\n   280→                assert result['duration'] < 30.0, f\"Transcription took too long: {result['duration']:.2f}s\"\n   281→                \n   282→                # Validate output makes sense for audio type\n   283→                assert TranscriptionTestData.validate_transcription_output(\n   284→                    audio_type, result['text_preview']\n   285→                ), f\"Invalid output for {audio_type}: '{result['text_preview']}'\"\n   286→    \n   287→    @pytest.mark.performance\n   288→    @pytest.mark.asyncio\n   289→    async def test_model_loading_performance(self, temp_dir, performance_timer):\n   290→        \"\"\"Test that model loading happens within reasonable time\"\"\"\n   291→        # Create service without pre-loaded model\n   292→        service = TranscriptionService(model_name=\"tiny\", audio_dir=temp_dir / \"audio\")\n   293→        \n   294→        # Time model loading\n   295→        performance_timer.start()\n   296→        service._load_model()\n   297→        load_time = performance_timer.stop()\n   298→        \n   299→        # Model loading should be reasonably fast for tiny model\n   300→        assert load_time < 60.0, f\"Model loading took too long: {load_time:.2f}s\"\n   301→        \n   302→        # Verify model was actually loaded\n   303→        assert service.model is not None\n   304→        \n   305→        print(f\"Tiny model loading time: {load_time:.2f}s\")\n   306→\n   307→\n   308→class TestTranscriptionErrorHandling:\n   309→    \"\"\"Test error handling and edge cases in transcription\"\"\"\n   310→    \n   311→    @pytest.mark.transcription\n   312→    @pytest.mark.asyncio\n   313→    async def test_corrupted_audio_file_handling(self, real_transcription_service, temp_dir):\n   314→        \"\"\"Test behavior with corrupted audio files\"\"\"\n   315→        service = real_transcription_service\n   316→        \n   317→        # Create corrupted audio file (not valid audio format)\n   318→        corrupted_file = temp_dir / \"corrupted.wav\"\n   319→        corrupted_file.write_bytes(b'This is not audio data' * 100)\n   320→        \n   321→        try:\n   322→            # Should raise appropriate error for corrupted file\n   323→            with pytest.raises(Exception):  # Whisper will raise some exception\n   324→                await service.transcribe_audio(corrupted_file, \"en\")\n   325→                \n   326→        finally:\n   327→            if corrupted_file.exists():\n   328→                corrupted_file.unlink()\n   329→    \n   330→    @pytest.mark.transcription\n   331→    @pytest.mark.asyncio  \n   332→    async def test_empty_audio_file_handling(self, real_transcription_service, temp_dir):\n   333→        \"\"\"Test behavior with empty audio files\"\"\"\n   334→        service = real_transcription_service\n   335→        \n   336→        # Create empty file\n   337→        empty_file = temp_dir / \"empty.wav\"\n   338→        empty_file.touch()\n   339→        \n   340→        try:\n   341→            # Should handle empty file gracefully or raise appropriate error\n   342→            with pytest.raises(Exception):\n   343→                await service.transcribe_audio(empty_file, \"en\")\n   344→                \n   345→        finally:\n   346→            if empty_file.exists():\n   347→                empty_file.unlink()\n   348→    \n   349→    @pytest.mark.transcription\n   350→    def test_service_with_invalid_audio_directory(self):\n   351→        \"\"\"Test service behavior with invalid audio directory\"\"\"\n   352→        # Try to create service with invalid directory path\n   353→        with pytest.raises(Exception):\n   354→            service = TranscriptionService(model_name=\"tiny\", audio_dir=\"/invalid/path/that/does/not/exist\")\n   355→            # Service creation might succeed, but directory creation should fail\n   356→            service._load_model()  # This or other operations should fail\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
