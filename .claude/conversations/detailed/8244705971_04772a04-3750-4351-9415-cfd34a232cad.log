   }\n    55→        \n    56→        container = ServiceContainer(config)\n    57→        \n    58→        # Check all services exist\n    59→        required_services = ['state', 'project', 'transcription', 'cleanup', 'config']\n    60→        for service_name in required_services:\n    61→            service = container.get(service_name)\n    62→            assert service is not None, f\"Service {service_name} not found\"\n    63→        \n    64→        # Cleanup\n    65→        Path('test_state.json').unlink(missing_ok=True)\n    66→    \n    67→    def test_state_persistence(self):\n    68→        \"\"\"Test state saving and loading\"\"\"\n    69→        from src.services.state import StateService\n    70→        \n    71→        test_file = Path(\"test_state.json\")\n    72→        \n    73→        # Create and modify state\n    74→        state = StateService(test_file)\n    75→        state.add_project(\"001\", \"Test Project\")\n    76→        state.set_active_project(\"001\")\n    77→        state.set_language(\"bg\")\n    78→        state.mark_message_processed(\"msg_123\")\n    79→        \n    80→        # Verify saved data\n    81→        with open(test_file, \"r\") as f:\n    82→            saved = json.load(f)\n    83→            assert saved[\"active_project\"] == \"001\"\n    84→            assert saved[\"language\"] == \"bg\"\n    85→            assert \"001\" in saved[\"projects\"]\n    86→            assert \"msg_123\" in saved[\"processed_messages\"]\n    87→        \n    88→        # Test loading\n    89→        state2 = StateService(test_file)\n    90→        assert state2.get_active_project() == \"001\"\n    91→        assert state2.get_language() == \"bg\"\n    92→        \n    93→        # Cleanup\n    94→        test_file.unlink()\n    95→    \n    96→    def test_project_management(self):\n    97→        \"\"\"Test project creation and management\"\"\"\n    98→        from src.services.project import ProjectService\n    99→        \n   100→        projects_dir = Path(\"./test_projects\")\n   101→        service = ProjectService(projects_dir)\n   102→        \n   103→        # Create project\n   104→        project_id = service.create_project(\"Test Project\", {})\n   105→        assert project_id == \"001\"\n   106→        \n   107→        # Add note\n   108→        success = service.add_note(\"001\", \"Test note\", \"Test translation\")\n   109→        assert success\n   110→        \n   111→        # Check files\n   112→        project_dir = service.get_project_dir(\"001\")\n   113→        assert project_dir.exists()\n   114→        notes_file = project_dir / \"notes.md\"\n   115→        assert notes_file.exists()\n   116→        \n   117→        # Get stats\n   118→        messages, words = service.get_project_stats(\"001\")\n   119→        assert messages > 0\n   120→        assert words > 0\n   121→        \n   122→        # Archive\n   123→        archived = service.archive_project(\"001\")\n   124→        assert archived\n   125→        assert not project_dir.exists()\n   126→        \n   127→        # Cleanup\n   128→        shutil.rmtree(projects_dir.parent / \"archive\", ignore_errors=True)\n   129→        shutil.rmtree(projects_dir, ignore_errors=True)\n   130→    \n   131→    def test_language_settings(self):\n   132→        \"\"\"Test language configuration\"\"\"\n   133→        from src.services.state import StateService\n   134→        \n   135→        test_file = Path(\"test_state.json\")\n   136→        state = StateService(test_file)\n   137→        \n   138→        # Test default\n   139→        assert state.get_language() == \"en\"\n   140→        \n   141→        # Test setting\n   142→        state.set_language(\"bg\")\n   143→        assert state.get_language() == \"bg\"\n   144→        \n   145→        # Test persistence\n   146→        state2 = StateService(test_file)\n   147→        assert state2.get_language() == \"bg\"\n   148→        \n   149→        # Cleanup\n   150→        test_file.unlink()\n   151→    \n   152→    def test_cleanup_service(self):\n   153→        \"\"\"Test cleanup functionality\"\"\"\n   154→        from src.services.cleanup import CleanupService\n   155→        \n   156→        # Setup\n   157→        audio_dir = Path(\"./test_audio\")\n   158→        logs_dir = Path(\"./test_logs\")\n   159→        audio_dir.mkdir(exist_ok=True)\n   160→        logs_dir.mkdir(exist_ok=True)\n   161→        \n   162→        cleanup = CleanupService(audio_dir, logs_dir)\n   163→        \n   164→        # Test audio cleanup\n   165→        old_file = audio_dir / \"old.ogg\"\n   166→        new_file = audio_dir / \"new.ogg\"\n   167→        old_file.touch()\n   168→        new_file.touch()\n   169→        \n   170→        # Make old file 8 days old\n   171→        old_time = (datetime.now() - timedelta(days=8)).timestamp()\n   172→        os.utime(old_file, (old_time, old_time))\n   173→        \n   174→        deleted = cleanup.cleanup_old_audio_files()\n   175→        assert deleted == 1\n   176→        assert not old_file.exists()\n   177→        assert new_file.exists()\n   178→        \n   179→        # Test log rotation\n   180→        log_file = logs_dir / \"bot.log\"\n   181→        with open(log_file, \"w\") as f:\n   182→            for i in range(1500):\n   183→                f.write(f\"Line {i}\\n\")\n   184→        \n   185→        rotated = cleanup.rotate_log_file(\"bot.log\")\n   186→        assert rotated\n   187→        \n   188→        with open(log_file, \"r\") as f:\n   189→            lines = f.readlines()\n   190→            assert len(lines) == 1000\n   191→        \n   192→        # Cleanup\n   193→        shutil.rmtree(audio_dir)\n   194→        shutil.rmtree(logs_dir)\n   195→    \n   196→    def test_command_registration(self):\n   197→        \"\"\"Test command registration system\"\"\"\n   198→        from src.core.registry import CommandRegistry\n   199→        from src.core.command import Command\n   200→        \n   201→        class TestCommand(Command):\n   202→            @property\n   203→            def name(self):\n   204→                return \"test\"\n   205→            \n   206→            @property\n   207→            def description(self):\n   208→                return \"Test command\"\n   209→            \n   210→            async def execute(self, update, context):\n   211→                pass\n   212→        \n   213→        registry = CommandRegistry()\n   214→        test_cmd = TestCommand({})  # Initialize command with empty services\n   215→        registry.register(test_cmd)\n   216→        \n   217→        # Check command is registered\n   218→        assert \"test\" in registry.commands\n   219→        cmd = registry.get_command(\"test\")\n   220→        assert cmd is not None\n   221→        assert isinstance(cmd, TestCommand)\n   222→    \n   223→    def test_bot_initialization(self):\n   224→        \"\"\"Test bot can be initialized\"\"\"\n   225→        from src.core.bot import VoiceNotesBot\n   226→        \n   227→        config = {\n   228→            'telegram_token': 'test_token',\n   229→            'whisper_model': 'tiny',\n   230→            'projects_dir': './test_projects',\n   231→            'audio_dir': './test_audio',\n   232→            'logs_dir': './test_logs',\n   233→            'state_file': 'test_state.json'\n   234→        }\n   235→        \n   236→        bot = VoiceNotesBot(config)\n   237→        \n   238→        # Check services\n   239→        assert bot.container.get('state') is not None\n   240→        assert bot.container.get('project') is not None\n   241→        assert bot.container.get('cleanup') is not None\n   242→        \n   243→        # Check directories\n   244→        assert Path('./test_projects').exists()\n   245→        assert Path('./test_audio').exists()\n   246→        assert Path('./test_logs').exists()\n   247→        \n   248→        # Cleanup\n   249→        shutil.rmtree('./test_projects', ignore_errors=True)\n   250→        shutil.rmtree('./test_audio', ignore_errors=True)\n   251→        shutil.rmtree('./test_logs', ignore_errors=True)\n   252→        Path('test_state.json').unlink(missing_ok=True)\n   253→    \n   254→    def run_all(self):\n   255→        \"\"\"Run all tests\"\"\"\n   256→        print(f\"{YELLOW}{'='*50}\")\n   257→        print(f\"Phone-to-Laptop Bot Test Suite\")\n   258→        print(f\"{'='*50}{RESET}\")\n   259→        \n   260→        # Run each test\n   261→        self.run_test(\"Service Initialization\", self.test_service_initialization)\n   262→        self.run_test(\"State Persistence\", self.test_state_persistence)\n   263→        self.run_test(\"Project Management\", self.test_project_management)\n   264→        self.run_test(\"Language Settings\", self.test_language_settings)\n   265→        self.run_test(\"Cleanup Service\", self.test_cleanup_service)\n   266→        self.run_test(\"Command Registration\", self.test_command_registration)\n   267→        self.run_test(\"Bot Initialization\", self.test_bot_initialization)\n   268→        \n   269→        # Print summary\n   270→        print(f\"\\n{YELLOW}{'='*50}\")\n   271→        print(f\"Test Results Summary\")\n   272→        print(f\"{'='*50}{RESET}\")\n   273→        print(f\"{GREEN}✅ Passed: {self.passed}{RESET}\")\n   274→        print(f\"{RED}❌ Failed: {self.failed}{RESET}\")\n   275→        \n   276→        # Detailed results\n   277→        if '--verbose' in sys.argv or self.failed > 0:\n   278→            print(f\"\\n{YELLOW}Detailed Results:{RESET}\")\n   279→            for name, passed, error in self.tests:\n   280→                if passed:\n   281→                    print(f\"  {GREEN}✓{RESET} {name}\")\n   282→                else:\n   283→                    print(f\"  {RED}✗{RESET} {name}\")\n   284→                    if error:\n   285→                        print(f\"    {RED}→ {error}{RESET}\")\n   286→        \n   287→        print(f\"\\n{YELLOW}{'='*50}{RESET}\")\n   288→        \n   289→        # Return exit code\n   290→        return 0 if self.failed == 0 else 1\n   291→\n   292→\n   293→if __name__ == \"__main__\":\n   294→    runner = TestRunner()\n   295→    sys.exit(runner.run_all())\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
