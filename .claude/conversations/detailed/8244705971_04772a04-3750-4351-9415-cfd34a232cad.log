ranscription complete. Language: {language}\")\n    48→        \n    49→        return transcribed_text, language\n    50→    \n    51→    async def translate_to_english(self, audio_path: Path, source_language: str) -> str:\n    52→        \"\"\"Translate audio to English\"\"\"\n    53→        self._load_model()\n    54→        \n    55→        self.logger.info(f\"Translating {source_language} audio to English\")\n    56→        \n    57→        result = self.model.transcribe(\n    58→            str(audio_path),\n    59→            language=source_language,\n    60→            task=\"translate\",  # Translate to English\n    61→            fp16=False\n    62→        )\n    63→        \n    64→        translated_text = result[\"text\"].strip()\n    65→        self.logger.info(\"Translation complete\")\n    66→        \n    67→        return translated_text\n    68→    \n    69→    def create_temp_audio_file(self, suffix: str = '.ogg') -> Path:\n    70→        \"\"\"Create a temporary audio file\"\"\"\n    71→        tmp_file = tempfile.NamedTemporaryFile(\n    72→            suffix=suffix,\n    73→            dir=self.audio_dir,\n    74→            delete=False\n    75→        )\n    76→        return Path(tmp_file.name)\n    77→    \n    78→    def cleanup_audio_file(self, audio_path: Path) -> None:\n    79→        \"\"\"Delete audio file\"\"\"\n    80→        if audio_path.exists():\n    81→            audio_path.unlink()\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
