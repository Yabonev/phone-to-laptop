    "content": "     1→\"\"\"Tests for core bot components\"\"\"\n     2→import pytest\n     3→import logging\n     4→from unittest.mock import Mock, AsyncMock, patch\n     5→from pathlib import Path\n     6→\n     7→from src.core.bot import VoiceNotesBot\n     8→from src.core.registry import CommandRegistry\n     9→from src.core.command import Command, CallbackCommand, VoiceCommand\n    10→\n    11→\n    12→class TestCommand(Command):\n    13→    \"\"\"Test command implementation\"\"\"\n    14→    \n    15→    def __init__(self, services):\n    16→        super().__init__(services)\n    17→        self.executed = False\n    18→        \n    19→    @property\n    20→    def name(self):\n    21→        return \"test\"\n    22→    \n    23→    @property\n    24→    def description(self):\n    25→        return \"Test command\"\n    26→    \n    27→    async def execute(self, update, context):\n    28→        self.executed = True\n    29→\n    30→\n    31→class TestCallbackCommand(CallbackCommand):\n    32→    \"\"\"Test callback command implementation\"\"\"\n    33→    \n    34→    def __init__(self, services):\n    35→        super().__init__(services)\n    36→        self.callback_handled = False\n    37→        \n    38→    @property\n    39→    def name(self):\n    40→        return \"testcallback\"\n    41→    \n    42→    @property\n    43→    def description(self):\n    44→        return \"Test callback command\"\n    45→    \n    46→    def get_callback_patterns(self):\n    47→        return [\"test_\"]\n    48→    \n    49→    async def execute(self, update, context):\n    50→        pass\n    51→    \n    52→    async def handle_callback(self, update, context):\n    53→        self.callback_handled = True\n    54→\n    55→\n    56→class TestCommandRegistry:\n    57→    \"\"\"Test command registration and management\"\"\"\n    58→    \n    59→    def test_command_registration(self):\n    60→        \"\"\"Test registering basic commands\"\"\"\n    61→        registry = CommandRegistry()\n    62→        command = TestCommand({})\n    63→        \n    64→        registry.register(command)\n    65→        \n    66→        assert \"test\" in registry.commands\n    67→        assert registry.get_command(\"test\") == command\n    68→        \n    69→    def test_callback_registration(self):\n    70→        \"\"\"Test registering callback commands\"\"\"\n    71→        registry = CommandRegistry()\n    72→        command = TestCallbackCommand({})\n    73→        \n    74→        registry.register(command)\n    75→        \n    76→        # Should be in commands and callback handlers\n    77→        assert \"testcallback\" in registry.commands\n    78→        assert \"test_\" in registry.callback_handlers\n    79→        assert registry.callback_handlers[\"test_\"] == command\n    80→        \n    81→    def test_voice_handler_registration(self):\n    82→        \"\"\"Test registering voice handler\"\"\"\n    83→        registry = CommandRegistry()\n    84→        \n    85→        class TestVoiceCommand(VoiceCommand):\n    86→            @property\n    87→            def name(self):\n    88→                return \"voice\"\n    89→            \n    90→            @property\n    91→            def description(self):\n    92→                return \"Voice handler\"\n    93→            \n    94→            async def execute(self, update, context):\n    95→                pass\n    96→            \n    97→            async def handle_voice(self, update, context):\n    98→                pass\n    99→        \n   100→        voice_command = TestVoiceCommand({})\n   101→        registry.register(voice_command)\n   102→        \n   103→        assert registry.voice_handler == voice_command\n   104→        \n   105→    def test_unregister_command(self):\n   106→        \"\"\"Test unregistering commands\"\"\"\n   107→        registry = CommandRegistry()\n   108→        command = TestCommand({})\n   109→        \n   110→        registry.register(command)\n   111→        assert \"test\" in registry.commands\n   112→        \n   113→        registry.unregister(\"test\")\n   114→        assert \"test\" not in registry.commands\n   115→        \n   116→    def test_get_bot_commands(self):\n   117→        \"\"\"Test getting bot menu commands\"\"\"\n   118→        registry = CommandRegistry()\n   119→        \n   120→        # Add command that shows in menu\n   121→        command1 = TestCommand({})\n   122→        # show_in_menu is a property, not settable\n   123→        registry.register(command1)\n   124→        \n   125→        # Add command that doesn't show in menu\n   126→        command2 = TestCallbackCommand({})\n   127→        registry.register(command2)\n   128→        \n   129→        bot_commands = registry.get_bot_commands()\n   130→        \n   131→        # Both commands show in menu by default\n   132→        assert len(bot_commands) == 2\n   133→        \n   134→    def test_handle_callback_query(self):\n   135→        \"\"\"Test callback query routing\"\"\"\n   136→        registry = CommandRegistry()\n   137→        callback_cmd = TestCallbackCommand({})\n   138→        registry.register(callback_cmd)\n   139→        \n   140→        # Test matching callback\n   141→        handler = registry.get_callback_handler(\"test_123\")\n   142→        assert handler == callback_cmd\n   143→        \n   144→        # Test non-matching callback\n   145→        handler = registry.get_callback_handler(\"nomatch_123\")\n   146→        assert handler is None\n   147→\n   148→\n   149→class TestVoiceNotesBot:\n   150→    \"\"\"Test main bot class\"\"\"\n   151→    \n   152→    def test_bot_initialization(self, test_config):\n   153→        \"\"\"Test bot initializes with all components\"\"\"\n   154→        bot = VoiceNotesBot(test_config)\n   155→        \n   156→        # Check components exist\n   157→        assert bot.container is not None\n   158→        assert bot.registry is not None\n   159→        assert bot.config == test_config\n   160→        \n   161→    def test_directories_created(self, test_config, temp_dir):\n   162→        \"\"\"Test required directories are created\"\"\"\n   163→        bot = VoiceNotesBot(test_config)\n   164→        \n   165→        # Check directories exist\n   166→        assert Path(test_config['projects_dir']).exists()\n   167→        assert Path(test_config['audio_dir']).exists()\n   168→        assert Path(test_config['logs_dir']).exists()\n   169→        \n   170→    def test_command_registration(self, test_config):\n   171→        \"\"\"Test registering commands with bot\"\"\"\n   172→        bot = VoiceNotesBot(test_config)\n   173→        \n   174→        # Register test command\n   175→        bot.register_command(TestCommand)\n   176→        \n   177→        # Verify registration\n   178→        assert \"test\" in bot.registry.commands\n   179→        \n   180→    def test_multiple_command_registration(self, test_config):\n   181→        \"\"\"Test registering multiple commands\"\"\"\n   182→        bot = VoiceNotesBot(test_config)\n   183→        \n   184→        # Register multiple commands\n   185→        bot.register_commands(TestCommand, TestCallbackCommand)\n   186→        \n   187→        # Verify both registered\n   188→        assert \"test\" in bot.registry.commands\n   189→        assert \"testcallback\" in bot.registry.commands\n   190→        \n   191→    @pytest.mark.asyncio\n   192→    async def test_process_queued_messages_empty(self, test_config):\n   193→        \"\"\"Test processing when no queued messages\"\"\"\n   194→        bot = VoiceNotesBot(test_config)\n   195→        \n   196→        # Mock application\n   197→        app = Mock()\n   198→        app.bot = Mock()\n   199→        app.bot.get_updates = AsyncMock(return_value=[])\n   200→        \n   201→        # Process (should handle empty queue gracefully)\n   202→        await bot.process_queued_messages(app)\n   203→        \n   204→        # Verify no errors and state saved\n   205→        state = bot.container.get('state')\n   206→        assert state is not None\n   207→        \n   208→    @pytest.mark.asyncio\n   209→    async def test_setup_bot_menu(self, test_config):\n   210→        \"\"\"Test bot menu setup\"\"\"\n   211→        bot = VoiceNotesBot(test_config)\n   212→        \n   213→        # Add command with menu\n   214→        bot.register_command(TestCommand)\n   215→        \n   216→        # Mock application\n   217→        app = Mock()\n   218→        app.bot = Mock()\n   219→        app.bot.set_my_commands = AsyncMock()\n   220→        \n   221→        # Setup menu\n   222→        await bot.setup_bot_menu(app)\n   223→        \n   224→        # Verify menu was set\n   225→        app.bot.set_my_commands.assert_called_once()\n   226→        \n   227→    def test_bot_run_without_token(self):\n   228→        \"\"\"Test bot handles missing token gracefully\"\"\"\n   229→        config = {'telegram_token': None}\n   230→        bot = VoiceNotesBot(config)\n   231→        \n   232→        # Should return without error\n   233→        result = bot.run()\n   234→        assert result is None  # Exits early due to no token\n   235→\n   236→\n   237→class TestCommandBase:\n   238→    \"\"\"Test command base classes\"\"\"\n   239→    \n   240→    def test_command_initialization(self):\n   241→        \"\"\"Test command gets services\"\"\"\n   242→        services = {\n   243→            'state': Mock(),\n   244→            'project': Mock(),\n   245→            'config': {'test': 'value'},\n   246→            'logger': logging.getLogger('test')\n   247→        }\n   248→        \n   249→        command = TestCommand(services)\n   250→        \n   251→        assert command.state == services['state']\n   252→        assert command.project_service == services['project']\n   253→        # config is stored in services dict, not as separate attribute\n   254→        assert command.services['config'] == services['config']\n   255→        \n   256→    def test_command_show_in_menu_default(self):\n   257→        \"\"\"Test default menu visibility\"\"\"\n   258→        command = TestCommand({})\n   259→        assert command.show_in_menu is True\n   260→        \n   261→    def test_command_menu_icon_default(self):\n   262→        \"\"\"Test default menu icon\"\"\"\n   263→        command = TestCommand({})\n   264→        assert command.menu_icon == \"\"\n   265→        \n   266→    def test_callback_command_patterns(self):\n   267→        \"\"\"Test callback command must implement patterns\"\"\"\n   268→        command = TestCallbackCommand({})\n   269→        patterns = command.get_callback_patterns()\n   270→        \n   271→        assert isinstance(patterns, list)\n   272→        assert len(patterns) > 0\n   273→        assert all(isinstance(p, str) for p in patterns)\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
