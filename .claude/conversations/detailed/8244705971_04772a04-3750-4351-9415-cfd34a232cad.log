ert \"**English:** This is a test\" in content\n   180→        \n   181→    def test_project_stats(self, temp_dir):\n   182→        \"\"\"Test getting project statistics\"\"\"\n   183→        projects_dir = temp_dir / \"projects\"\n   184→        service = ProjectService(projects_dir)\n   185→        \n   186→        # Create project and add notes\n   187→        project_id = service.create_project(\"Test\", {})\n   188→        service.add_note(project_id, \"First note with some words\")\n   189→        service.add_note(project_id, \"Second note with more words here\")\n   190→        \n   191→        # Get stats\n   192→        messages, words = service.get_project_stats(project_id)\n   193→        assert messages == 2\n   194→        assert words > 0  # Should count all words\n   195→        \n   196→    def test_project_archival(self, temp_dir):\n   197→        \"\"\"Test archiving projects\"\"\"\n   198→        projects_dir = temp_dir / \"projects\"\n   199→        service = ProjectService(projects_dir)\n   200→        \n   201→        # Create and archive project\n   202→        project_id = service.create_project(\"To Archive\", {})\n   203→        project_dir = service.get_project_dir(project_id)\n   204→        \n   205→        # Archive it\n   206→        success = service.archive_project(project_id)\n   207→        assert success\n   208→        assert not project_dir.exists()\n   209→        \n   210→        # Check archive exists\n   211→        archive_dir = temp_dir / \"archive\"\n   212→        assert archive_dir.exists()\n   213→        archived = list(archive_dir.glob(\"project-001-*\"))\n   214→        assert len(archived) == 1\n   215→\n   216→\n   217→class TestCleanupService:\n   218→    \"\"\"Test cleanup and maintenance functionality\"\"\"\n   219→    \n   220→    def test_old_audio_cleanup(self, temp_dir):\n   221→        \"\"\"Test deletion of old audio files\"\"\"\n   222→        audio_dir = temp_dir / \"audio\"\n   223→        audio_dir.mkdir()\n   224→        \n   225→        # Create old and new files\n   226→        old_file = audio_dir / \"old.ogg\"\n   227→        new_file = audio_dir / \"new.ogg\"\n   228→        old_file.touch()\n   229→        new_file.touch()\n   230→        \n   231→        # Make old file 8 days old\n   232→        old_time = (datetime.now() - timedelta(days=8)).timestamp()\n   233→        os.utime(old_file, (old_time, old_time))\n   234→        \n   235→        # Run cleanup\n   236→        cleanup = CleanupService(audio_dir, temp_dir / \"logs\")\n   237→        deleted_count = cleanup.cleanup_old_audio_files()\n   238→        \n   239→        assert deleted_count == 1\n   240→        assert not old_file.exists()\n   241→        assert new_file.exists()\n   242→        \n   243→    def test_audio_cleanup_retention(self, temp_dir):\n   244→        \"\"\"Test that recent files are kept\"\"\"\n   245→        audio_dir = temp_dir / \"audio\"\n   246→        audio_dir.mkdir()\n   247→        \n   248→        # Create files of various ages\n   249→        for days_old in [1, 3, 5, 6, 7, 8, 10]:\n   250→            file = audio_dir / f\"file_{days_old}d.ogg\"\n   251→            file.touch()\n   252→            file_time = (datetime.now() - timedelta(days=days_old)).timestamp()\n   253→            os.utime(file, (file_time, file_time))\n   254→        \n   255→        # Run cleanup (7 day retention)\n   256→        cleanup = CleanupService(audio_dir, temp_dir / \"logs\")\n   257→        deleted_count = cleanup.cleanup_old_audio_files()\n   258→        \n   259→        # Files 7, 8 and 10 days old should be deleted (>= 7 days)\n   260→        assert deleted_count == 3\n   261→        assert not (audio_dir / \"file_8d.ogg\").exists()\n   262→        assert not (audio_dir / \"file_10d.ogg\").exists()\n   263→        \n   264→        # Files less than 7 days should exist\n   265→        for days in [1, 3, 5, 6]:\n   266→            assert (audio_dir / f\"file_{days}d.ogg\").exists()\n   267→        # 7 day old file should be deleted\n   268→        assert not (audio_dir / \"file_7d.ogg\").exists()\n   269→            \n   270→    def test_log_rotation(self, temp_dir):\n   271→        \"\"\"Test log file rotation\"\"\"\n   272→        logs_dir = temp_dir / \"logs\"\n   273→        logs_dir.mkdir()\n   274→        log_file = logs_dir / \"bot.log\"\n   275→        \n   276→        # Create large log file\n   277→        with open(log_file, \"w\") as f:\n   278→            for i in range(1500):\n   279→                f.write(f\"Line {i}\\n\")\n   280→        \n   281→        # Run rotation\n   282→        cleanup = CleanupService(temp_dir / \"audio\", logs_dir)\n   283→        rotated = cleanup.rotate_log_file(\"bot.log\")\n   284→        \n   285→        assert rotated is True\n   286→        \n   287→        # Check file was truncated\n   288→        with open(log_file, \"r\") as f:\n   289→            lines = f.readlines()\n   290→            assert len(lines) == 1000\n   291→            # Should keep last 1000 lines (500-1499)\n   292→            assert lines[0].strip() == \"Line 500\"\n   293→            assert lines[-1].strip() == \"Line 1499\"\n   294→            \n   295→    def test_log_rotation_small_file(self, temp_dir):\n   296→        \"\"\"Test that small logs are not rotated\"\"\"\n   297→        logs_dir = temp_dir / \"logs\"\n   298→        logs_dir.mkdir()\n   299→        log_file = logs_dir / \"bot.log\"\n   300→        \n   301→        # Create small log file\n   302→        with open(log_file, \"w\") as f:\n   303→            for i in range(500):\n   304→                f.write(f\"Line {i}\\n\")\n   305→        \n   306→        # Run rotation\n   307→        cleanup = CleanupService(temp_dir / \"audio\", logs_dir)\n   308→        rotated = cleanup.rotate_log_file(\"bot.log\")\n   309→        \n   310→        assert rotated is False\n   311→        \n   312→        # Check file unchanged\n   313→        with open(log_file, \"r\") as f:\n   314→            lines = f.readlines()\n   315→            assert len(lines) == 500\n   316→            \n   317→    def test_full_cleanup_run(self, temp_dir):\n   318→        \"\"\"Test running all cleanup tasks\"\"\"\n   319→        audio_dir = temp_dir / \"audio\"\n   320→        logs_dir = temp_dir / \"logs\"\n   321→        audio_dir.mkdir()\n   322→        logs_dir.mkdir()\n   323→        \n   324→        # Create old audio file\n   325→        old_audio = audio_dir / \"old.ogg\"\n   326→        old_audio.touch()\n   327→        old_time = (datetime.now() - timedelta(days=10)).timestamp()\n   328→        os.utime(old_audio, (old_time, old_time))\n   329→        \n   330→        # Create large log\n   331→        log_file = logs_dir / \"bot.log\"\n   332→        with open(log_file, \"w\") as f:\n   333→            for i in range(1200):\n   334→                f.write(f\"Line {i}\\n\")\n   335→        \n   336→        # Run full cleanup\n   337→        cleanup = CleanupService(audio_dir, logs_dir)\n   338→        cleanup.run_cleanup()\n   339→        \n   340→        # Verify results\n   341→        assert not old_audio.exists()\n   342→        with open(log_file, \"r\") as f:\n   343→            assert len(f.readlines()) == 1000\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"
