    "content": "     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Telegram Voice Notes Bot - Captures voice messages and transcribes them to project folders\n     4→\"\"\"\n     5→\n     6→import os\n     7→import json\n     8→import asyncio\n     9→import logging\n    10→from datetime import datetime\n    11→from pathlib import Path\n    12→from typing import Dict, Optional, List\n    13→import tempfile\n    14→\n    15→from telegram import Update, Bot, InlineKeyboardButton, InlineKeyboardMarkup\n    16→from telegram.ext import Application, CommandHandler, MessageHandler, filters, ContextTypes, CallbackQueryHandler\n    17→from pydantic import BaseModel, Field\n    18→from dotenv import load_dotenv\n    19→from rich.console import Console\n    20→from rich.logging import RichHandler\n    21→import whisper\n    22→\n    23→# Load environment variables\n    24→load_dotenv()\n    25→\n    26→# Setup logging\n    27→console = Console()\n    28→logging.basicConfig(\n    29→    level=logging.INFO,\n    30→    format=\"%(message)s\",\n    31→    datefmt=\"[%X]\",\n    32→    handlers=[\n    33→        RichHandler(rich_tracebacks=True),\n    34→        logging.FileHandler(\"logs/bot.log\", mode='a')\n    35→    ]\n    36→)\n    37→logger = logging.getLogger(__name__)\n    38→\n    39→# Configuration\n    40→class Config(BaseModel):\n    41→    telegram_token: str = Field(default_factory=lambda: os.getenv(\"TELEGRAM_TOKEN\", \"\"))\n    42→    whisper_model: str = Field(default_factory=lambda: os.getenv(\"WHISPER_MODEL\", \"base\"))\n    43→    projects_dir: Path = Field(default_factory=lambda: Path(os.getenv(\"PROJECTS_DIR\", \"./projects\")))\n    44→    audio_dir: Path = Field(default_factory=lambda: Path(os.getenv(\"AUDIO_DIR\", \"./audio\")))\n    45→    logs_dir: Path = Field(default_factory=lambda: Path(os.getenv(\"LOGS_DIR\", \"./logs\")))\n    46→    timezone: str = Field(default_factory=lambda: os.getenv(\"TIMEZONE\", \"UTC\"))\n    47→    check_interval: int = Field(default_factory=lambda: int(os.getenv(\"CHECK_INTERVAL\", \"60\")))\n    48→    offline_response: str = Field(default_factory=lambda: os.getenv(\"OFFLINE_RESPONSE\", \"💻 Laptop is offline. Message queued for processing.\"))\n    49→\n    50→# State management\n    51→class BotState(BaseModel):\n    52→    last_update_id: Optional[int] = None\n    53→    active_project: Optional[str] = None  # Single active project\n    54→    processed_messages: List[str] = Field(default_factory=list)\n    55→    projects: Dict[str, str] = Field(default_factory=dict)  # project_id -> project_name\n    56→    language: str = \"en\"  # Single language setting\n    57→\n    58→class VoiceNotesBot:\n    59→    def __init__(self, config: Config):\n    60→        self.config = config\n    61→        self.state_file = Path(\"state.json\")\n    62→        self.state = self.load_state()\n    63→        self.whisper_model = None\n    64→        \n    65→        # Create directories\n    66→        self.config.projects_dir.mkdir(exist_ok=True)\n    67→        self.config.audio_dir.mkdir(exist_ok=True)\n    68→        self.config.logs_dir.mkdir(exist_ok=True)\n    69→        \n    70→        logger.info(f\"Bot initialized with projects dir: {self.config.projects_dir}\")\n    71→    \n    72→    def load_state(self) -> BotState:\n    73→        \"\"\"Load bot state from file\"\"\"\n    74→        if self.state_file.exists():\n    75→            with open(self.state_file, 'r') as f:\n    76→                data = json.load(f)\n    77→                return BotState(**data)\n    78→        return BotState()\n    79→    \n    80→    def save_state(self):\n    81→        \"\"\"Save bot state to file\"\"\"\n    82→        with open(self.state_file, 'w') as f:\n    83→            json.dump(self.state.model_dump(), f, indent=2)\n    84→    \n    85→    def load_whisper(self):\n    86→        \"\"\"Load Whisper model (lazy loading)\"\"\"\n    87→        if self.whisper_model is None:\n    88→            logger.info(f\"Loading Whisper model: {self.config.whisper_model}\")\n    89→            self.whisper_model = whisper.load_model(self.config.whisper_model)\n    90→            logger.info(\"Whisper model loaded successfully\")\n    91→    \n    92→    def get_help_message(self, user_id: str) -> str:\n    93→        \"\"\"Get help message with current user settings\"\"\"\n    94→        lang_name = {\"en\": \"English\", \"bg\": \"Bulgarian\", \"auto\": \"Auto-detect\"}.get(self.state.language, self.state.language)\n    95→        \n    96→        # Check if user has active project\n    97→        active_project = None\n    98→        if user_id in self.state.active_sessions:\n    99→            project_id = self.state.active_sessions[user_id]\n   100→            active_project = self.state.projects.get(project_id)\n   101→        \n   102→        message = (\n   103→            \"🎤 Voice Notes Bot\\n\\n\"\n   104→            \"💡 Type / to see all commands\\n\"\n   105→            \"/projects to select a project\\n\\n\"\n   106→            \"🌐 Language: \" + lang_name + \"\\n\"\n   107→            \"Quick set: /language en or /language bg\\n\\n\"\n   108→        )\n   109→        \n   110→        if active_project:\n   111→            message += f'📂 Active: \"{active_project}\"\\n'\n   112→        else:\n   113→            message += \"⚠️ No project selected\\n\"\n   114→        \n   115→        message += \"\\n💡 Send voice messages after selecting a project!\"\n   116→        return message\n   117→    \n   118→    async def start_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):\n   119→        \"\"\"Handle /start command\"\"\"\n   120→        user_id = str(update.effective_user.id)\n   121→        \n   122→        # Set default language to English if not set\n   123→        if user_id not in self.state.user_languages:\n   124→            self.state.user_languages[user_id] = \"en\"\n   125→            self.save_state()\n   126→        \n   127→        await update.message.reply_text(self.get_help_message(user_id))\n   128→        logger.info(f\"User {user_id} started bot\")\n   129→    \n   130→    \n   131→    async def projects_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):\n   132→        \"\"\"Handle /projects command\"\"\"\n   133→        if not self.state.projects:\n   134→            await update.message.reply_text(\"📂 No projects yet. Create one with /new <name>\")\n   135→            return\n   136→        \n   137→        # Create buttons for project selection (newest first)\n   138→        keyboard = []\n   139→        # Sort projects by ID in reverse order (newest first)\n   140→        sorted_projects = sorted(self.state.projects.items(), key=lambda x: x[0], reverse=True)\n   141→        \n   142→        for pid, name in sorted_projects:\n   143→            # Add select and delete buttons with padding to make project button larger\n   144→            # Pad the project name to make it take more visual space\n   145→            padded_name = f'📂 {pid}. {name}                    '\n   146→            keyboard.append([\n   147→                InlineKeyboardButton(padded_name, callback_data=f\"pick_{pid}\"),\n   148→                InlineKeyboardButton('🗑️', callback_data=f\"del_{pid}\")\n   149→            ])\n   150→        \n   151→        reply_markup = InlineKeyboardMarkup(keyboard)\n   152→        await update.message.reply_text(\"📁 Select or delete a project:\", reply_markup=reply_markup)\n   153→    \n   154→    async def new_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):\n   155→        \"\"\"Handle /new <name> command\"\"\"\n   156→        if not context.args:\n   157→            await update.message.reply_text(\"❌ Usage: /new <project_name>\")\n   158→            return\n   159→        \n   160→        project_name = \" \".join(context.args)\n   161→        # Sanitize project name for filesystem\n   162→        safe_name = \"\".join(c for c in project_name if c.isalnum() or c in (' ', '-', '_')).rstrip()\n   163→        \n   164→        # Generate project ID (3-digit) - find the highest ID and add 1\n   165→        if self.state.projects:\n   166→            max_id = max(int(pid) for pid in self.state.projects.keys())\n   167→            project_id = str(max_id + 1).zfill(3)\n   168→        else:\n   169→            project_id = \"001\"\n   170→        \n   171→        # Create project directory\n   172→        project_dir = self.config.projects_dir / f\"project-{project_id}-{safe_name.replace(' ', '-').lower()}\"\n   173→        project_dir.mkdir(exist_ok=True)\n   174→        \n   175→        # Create notes file\n   176→        notes_file = project_dir / \"notes.md\"\n   177→        notes_file.write_text(f\"# {project_name}\\n\\nVoice notes transcriptions:\\n\\n\")\n   178→        \n   179→        # Save to state\n   180→        self.state.projects[project_id] = project_name\n   181→        self.save_state()\n   182→        \n   183→        await update.message.reply_text(f'✅ Created project \"{project_name}\" (ID: {project_id})')\n   184→        logger.info(f\"Created project {project_id}: {project_name}\")\n   185→    \n   186→    \n   187→    async def status_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):\n   188→        \"\"\"Handle /status command\"\"\"\n   189→        user_id = str(update.effective_user.id)\n   190→        \n   191→        if user_id not in self.state.active_sessions:\n   192→            await update.message.reply_text(\"❌ No active project. Use /pick <id> to select one.\")\n   193→            return\n   194→        \n   195→        project_id = self.state.active_sessions[user_id]\n   196→        project_name = self.state.projects[project_id]\n   197→        \n   198→        # Get project statistics\n   199→        project_dir = None\n   200→        for dir in self.config.projects_dir.iterdir():\n   201→            if dir.name.startswith(f\"project-{project_id}-\"):\n   202→                project_dir = dir\n   203→                break\n   204→        \n   205→        message_count = 0\n   206→        total_words = 0\n   207→        \n   208→        if project_dir:\n   209→            notes_file = project_dir / \"notes.md\"\n   210→            if notes_file.exists():\n   211→                content = notes_file.read_text()\n   212→                # Count sections (each voice message creates a ## timestamp section)\n   213→                message_count = content.count(\"\\n## \")\n   214→                # Count words (excluding markdown headers and empty lines)\n   215→                lines = content.split('\\n')\n   216→                for line in lines:\n   217→                    if line and not line.startswith('#'):\n   218→                        total_words += len(line.split())\n   219→        \n   220→        lang_name = {\"en\": \"English\", \"bg\": \"Bulgarian\", \"auto\": \"Auto-detect\"}.get(self.state.language, self.state.language)\n   221→        \n   222→        await update.message.reply_text(\n   223→            f'📂 Project: \"{project_name}\" (ID: {project_id})\\n'\n   224→            f'📝 Messages: {message_count}\\n'\n   225→            f'📊 Total words: {total_words}\\n'\n   226→            f'🌐 Language: {lang_name}'\n   227→        )\n   228→    \n   229→    async def language_command(self, update: Update, context: ContextTypes.DEFAULT_TYPE):\n   230→        \"\"\"Handle /language command\"\"\"\n   231→        user_id = str(update.effective_user.id)\n   232→        current_lang = self.state.user_languages.get(user_id, \"en\")\n   233→        \n   234→        # Create language selection buttons\n   235→        keyboard = [\n   236→            [InlineKeyboardButton(\"🇬🇧 English\" + (\" ✓\" if current_lang == \"en\" else \"\"), callback_data=\"lang_en\")],\n   237→            [InlineKeyboardButton(\"🇧🇬 Bulgarian\" + (\" ✓\" if current_lang == \"bg\" else \"\"), callback_data=\"lang_bg\")],\n   238→            [InlineKeyboardButton(\"🤖 Auto-detect\" + (\" ✓\" if current_lang == \"auto\" else \"\"), callback_data=\"lang_auto\")]\n   239→        ]\n   240→        \n   241→        reply_markup = InlineKeyboardMarkup(keyboard)\n   242→        await update.message.reply_text(\"🌐 Select transcription language:\", reply_markup=reply_markup)\n   243→    \n   244→    async def button_callback(self, update: Update, context: ContextTypes.DEFAULT_TYPE):\n   245→        \"\"\"Handle button presses\"\"\"\n   246→        query = update.callback_query\n   247→        user_id = str(query.from_user.id)\n   248→        \n   249→        # Acknowledge the button press\n   250→        await query.answer()\n   251→        \n   252→        # Handle project selection\n   253→        if query.data.startswith(\"pick_\"):\n   254→            project_id = query.data.replace(\"pick_\", \"\")\n   255→            \n   256→            if project_id not in self.state.projects:\n   257→                await query.edit_message_text(f\"❌ Project {project_id} not found.\")\n   258→                return\n   259→            \n   260→            # Set active project\n   261→            self.state.active_sessions[user_id] = project_id\n   262→            self.save_state()\n   263→            \n   264→            project_name = self.state.projects[project_id]\n   265→            await query.edit_message_text(\n   266→                f'✅ Selected project \"{project_name}\"\\n'\n   267→                \"🎤 Send voice messages...\"\n   268→            )\n   269→            logger.info(f\"User {user_id} selected project {project_id} via button\")\n   270→        \n   271→        # Handle language selection\n   272→        elif query.data.startswith(\"lang_\"):\n   273→            lang_code = query.data.replace(\"lang_\", \"\")\n   274→            \n   275→            self.state.user_languages[user_id] = lang_code\n   276→            self.save_state()\n   277→            \n   278→            lang_names = {\n   279→                \"en\": \"English\",\n   280→                \"bg\": \"Bulgarian\",\n   281→                \"auto\": \"Auto-detect\"\n   282→            }\n   283→            \n   284→            lang_name = lang_names.get(lang_code, lang_code)\n   285→            await query.edit_message_text(f\"✅ Language set to: {lang_name}\")\n   286→            logger.info(f\"User {user_id} set language to {lang_code} via button\")\n   287→        \n   288→        # Handle project deletion request\n   289→        elif query.data.startswith(\"del_\"):\n   290→            project_id = query.data.replace(\"del_\", \"\")\n   291→            \n   292→            if project_id not in self.state.projects:\n   293→                await query.edit_message_text(f\"❌ Project {project_id} not found.\")\n   294→                return\n   295→            \n   296→            project_name = self.state.projects[project_id]\n   297→            \n   298→            # Show confirmation dialog\n   299→            keyboard = [\n   300→                [\n   301→                    InlineKeyboardButton(\"❌ Yes, delete\", callback_data=f\"confirm_del_{project_id}\"),\n   302→                    InlineKeyboardButton(\"✅ Keep it\", callback_data=\"cancel_del\")\n   303→                ]\n   304→            ]\n   305→            reply_markup = InlineKeyboardMarkup(keyboard)\n   306→            \n   307→            await query.edit_message_text(\n   308→                f'⚠️ Delete project \"{project_name}\"?\\n\\n'\n   309→                \"This will permanently delete all notes in this project.\",\n   310→                reply_markup=reply_markup\n   311→            )\n   312→        \n   313→        # Handle deletion confirmation\n   314→        elif query.data.startswith(\"confirm_del_\"):\n   315→            project_id = query.data.replace(\"confirm_del_\", \"\")\n   316→            \n   317→            if project_id not in self.state.projects:\n   318→                await query.edit_message_text(f\"❌ Project {project_id} not found.\")\n   319→                return\n   320→            \n   321→            project_name = self.state.projects[project_id]\n   322→            \n   323→            # Remove project from state\n   324→            del self.state.projects[project_id]\n   325→            \n   326→            # If this was the active project, clear it\n   327→            if user_id in self.state.active_sessions and self.state.active_sessions[user_id] == project_id:\n   328→                del self.state.active_sessions[user_id]\n   329→            \n   330→            self.save_state()\n   331→            \n   332→            # Delete project directory\n   333→            import shutil\n   334→            for dir in self.config.projects_dir.iterdir():\n   335→                if dir.name.startswith(f\"project-{project_id}-\"):\n   336→                    shutil.rmtree(dir)\n   337→                    break\n   338→            \n   339→            await query.edit_message_text(f'🗑️ Deleted project \"{project_name}\"')\n   340→            logger.info(f\"User {user_id} deleted project {project_id}\")\n   341→        \n   342→        # Handle deletion cancellation\n   343→        elif query.data == \"cancel_del\":\n   344→            await query.edit_message_text(\"✅ Deletion cancelled. Use /projects to see your projects.\")\n   345→    \n   346→    async def handle_voice(self, update: Update, context: ContextTypes.DEFAULT_TYPE):\n   347→        \"\"\"Handle voice messages\"\"\"\n   348→        user_id = str(update.effective_user.id)\n   349→        message_id = str(update.message.message_id)\n   350→        \n   351→        # Check if message was already processed (for queue handling)\n   352→        if message_id in self.state.processed_messages:\n   353→            logger.info(f\"Skipping already processed message {message_id}\")\n   354→            return\n   355→        \n   356→        # Check if user has active project\n   357→        if user_id not in self.state.active_sessions:\n   358→            await update.message.reply_text(\"❌ No project selected. Use /pick <id> first.\")\n   359→            return\n   360→        \n   361→        project_id = self.state.active_sessions[user_id]\n   362→        project_name = self.state.projects[project_id]\n   363→        \n   364→        # Send processing indicator\n   365→        processing_msg = await update.message.reply_text(\"📝 Processing...\")\n   366→        \n   367→        try:\n   368→            # Download voice file\n   369→            voice_file = await update.message.voice.get_file()\n   370→            \n   371→            # Create temporary file for audio\n   372→            with tempfile.NamedTemporaryFile(suffix='.ogg', dir=self.config.audio_dir, delete=False) as tmp_file:\n   373→                audio_path = Path(tmp_file.name)\n   374→                await voice_file.download_to_drive(audio_path)\n   375→            \n   376→            # Load Whisper if needed\n   377→            self.load_whisper()\n   378→            \n   379→            # Get user's language preference (default to English)\n   380→            user_lang = self.state.user_languages.get(user_id, \"en\")\n   381→            \n   382→            # Transcribe audio with user's selected language\n   383→            logger.info(f\"Transcribing audio file: {audio_path} (language: {user_lang})\")\n   384→            \n   385→            transcribe_params = {\"fp16\": False}  # Use FP32 for CPU\n   386→            if user_lang != \"auto\":\n   387→                transcribe_params[\"language\"] = user_lang\n   388→            \n   389→            result = self.whisper_model.transcribe(\n   390→                str(audio_path),\n   391→                **transcribe_params\n   392→            )\n   393→            transcribed_text = result[\"text\"].strip()\n   394→            detected_language = result.get(\"language\", user_lang)\n   395→            logger.info(f\"Language used: {detected_language}\")\n   396→            \n   397→            # If Bulgarian, also get English translation\n   398→            translated_text = None\n   399→            if user_lang == \"bg\" or detected_language == \"bg\":\n   400→                logger.info(\"Getting English translation...\")\n   401→                translate_result = self.whisper_model.transcribe(\n   402→                    str(audio_path),\n   403→                    language=\"bg\",\n   404→                    task=\"translate\",  # This translates to English\n   405→                    fp16=False\n   406→                )\n   407→                translated_text = translate_result[\"text\"].strip()\n   408→                logger.info(\"Translation complete\")\n   409→            \n   410→            # Delete audio file\n   411→            audio_path.unlink()\n   412→            \n   413→            # Get timestamp\n   414→            timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M\")\n   415→            \n   416→            # Find project directory\n   417→            project_dir = None\n   418→            for dir in self.config.projects_dir.iterdir():\n   419→                if dir.name.startswith(f\"project-{project_id}-\"):\n   420→                    project_dir = dir\n   421→                    break\n   422→            \n   423→            if not project_dir:\n   424→                raise Exception(f\"Project directory not found for ID {project_id}\")\n   425→            \n   426→            # Append to notes file\n   427→            notes_file = project_dir / \"notes.md\"\n   428→            with open(notes_file, 'a') as f:\n   429→                if translated_text:\n   430→                    # Write both Bulgarian and English\n   431→                    f.write(f\"## {timestamp}\\n\\n**Bulgarian:** {transcribed_text}\\n\\n**English:** {translated_text}\\n\\n\")\n   432→                else:\n   433→                    # Write just the transcription\n   434→                    f.write(f\"## {timestamp}\\n\\n{transcribed_text}\\n\\n\")\n   435→            \n   436→            # Mark message as processed\n   437→            self.state.processed_messages.append(message_id)\n   438→            self.save_state()\n   439→            \n   440→            # Update confirmation message with word count\n   441→            word_count = len(transcribed_text.split())\n   442→            await processing_msg.edit_text(\n   443→                f'✅ Added to project \"{project_name}\" ({word_count} words)'\n   444→            )\n   445→            \n   446→            logger.info(f\"Transcribed {word_count} words to project {project_id}\")\n   447→            \n   448→        except Exception as e:\n   449→            logger.error(f\"Error processing voice message: {e}\")\n   450→            await processing_msg.edit_text(f\"❌ Error: {str(e)}\")\n   451→    \n   452→    async def process_queued_messages(self, application: Application):\n   453→        \"\"\"Process messages that were sent while bot was offline\"\"\"\n   454→        logger.info(\"🔍 Checking for queued messages...\")\n   455→        \n   456→        try:\n   457→            # Get updates since last processed\n   458→            updates = await application.bot.get_updates(\n   459→                offset=self.state.last_update_id + 1 if self.state.last_update_id else 0\n   460→            )\n   461→            \n   462→            if updates:\n   463→                logger.info(f\"📬 Found {len(updates)} messages in queue. Starting batch processing...\")\n   464→                \n   465→                for idx, update in enumerate(updates, 1):\n   466→                    logger.info(f\"⏳ Processing queued message {idx}/{len(updates)}...\")\n   467→                    # Update last processed ID\n   468→                    self.state.last_update_id = update.update_id\n   469→                    \n   470→                    # Process voice messages\n   471→                    if update.message and update.message.voice:\n   472→                        # Temporarily set language to auto for queue processing\n   473→                        user_id = str(update.message.from_user.id)\n   474→                        original_lang = self.state.user_languages.get(user_id, \"en\")\n   475→                        self.state.user_languages[user_id] = \"auto\"\n   476→                        \n   477→                        logger.info(f\"🎤 Processing voice message from queue (auto-detect language)\")\n   478→                        await self.handle_voice(update, None)\n   479→                        \n   480→                        # Restore original language preference\n   481→                        self.state.user_languages[user_id] = original_lang\n   482→                    # Process commands\n   483→                    elif update.message and update.message.text:\n   484→                        text = update.message.text\n   485→                        if text.startswith('/'):\n   486→                            # Route to appropriate handler\n   487→                            if text.startswith('/start'):\n   488→                                await self.start_command(update, None)\n   489→                            elif text.startswith('/projects'):\n   490→                                await self.projects_command(update, None)\n   491→                            elif text.startswith('/new'):\n   492→                                # Parse args manually\n   493→                                parts = text.split(maxsplit=1)\n   494→                                if len(parts) > 1:\n   495→                                    context = type('obj', (object,), {'args': parts[1].split()})()\n   496→                                    await self.new_command(update, context)\n   497→                            elif text.startswith('/pick'):\n   498→                                parts = text.split()\n   499→                                if len(parts) > 1:\n   500→      