l send welcome\n        update.message.reply_text.assert_called_once()\n        message = update.message.reply_text.call_args[0][0]\n        assert \"Welcome\" in message\n        assert \"Voice Notes Bot\" in message\n\n\nclass TestBotRunMethod:\n    \"\"\"Test bot run method\"\"\"\n    \n    @patch('src.core.bot.Application')\n    def test_bot_run_with_token(self, mock_app_class, test_config):\n        \"\"\"Test bot.run() with valid token\"\"\"\n        # Setup mocks\n        mock_app = Mock()\n        mock_app_class.builder.return_value.token.return_value.build.return_value = mock_app\n        mock_app.run_polling = Mock()\n        \n        # Create bot with token\n        config = dict(test_config)\n        config['telegram_token'] = 'test_token_123'\n        bot = VoiceNotesBot(config)\n        \n        # Mock command registration\n        with patch.object(bot, '_register_all_commands'):\n            bot.run()\n        \n        # Should call run_polling\n        mock_app.run_polling.assert_called_once()\n        \n    @patch('src.core.bot.Application')  \n    def test_bot_run_registers_handlers(self, mock_app_class, test_config):\n        \"\"\"Test bot registers all handlers\"\"\"\n        # Setup mocks\n        mock_app = Mock()\n        mock_builder = Mock()\n        mock_app_class.builder.return_value = mock_builder\n        mock_builder.token.return_value = mock_builder\n        mock_builder.build.return_value = mock_app\n        mock_app.add_handler = Mock()\n        mock_app.run_polling = Mock()\n        \n        # Create bot with token\n        config = dict(test_config)\n        config['telegram_token'] = 'test_token_123'\n        bot = VoiceNotesBot(config)\n        \n        # Register test command\n        from tests.test_core import TestCommand\n        bot.register_command(TestCommand)\n        \n        # Run bot\n        bot.run()\n        \n        # Should have added handlers\n        assert mock_app.add_handler.called\n        \n       