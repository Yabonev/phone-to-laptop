d be handled\n        command.handle_callback.assert_called_once_with(update, context)\n        assert result is True\n        \n    def test_registry_process_update_voice(self):\n        \"\"\"Test processing voice update\"\"\"\n        registry = CommandRegistry()\n        \n        # Register voice handler\n        voice_handler = Mock()\n        voice_handler.handle_voice = AsyncMock()\n        registry.voice_handler = voice_handler\n        \n        # Create voice update\n        update = Mock()\n        update.message = Mock()\n        update.message.voice = Mock()\n        update.message.text = None\n        update.callback_query = None\n        \n        context = Mock()\n        \n        # Process\n        import asyncio\n        result = asyncio.run(registry.process_update(update, context))\n        \n        # Voice should be handled\n        voice_handler.handle_voice.assert_called_once_with(update, context)\n        assert result is True\n        \n    def test_registry_process_update_unknown(self):\n        \"\"\"Test processing unknown update type\"\"\"\n        registry = CommandRegistry()\n        \n        # Create unknown update\n        update = Mock()\n        update.message = Mock()\n        update.message.voice = None\n        update.message.text = \"not a command\"\n        update.callback_query = None\n        \n        context = Mock()\n        \n        # Process\n        import asyncio\n        result = asyncio.run(registry.process_update(update, context))\n        \n        # Should return False for unknown\n        assert result is False\n\n\nclass TestCommandProperties:\n    \"\"\"Test command menu icons and properties\"\"\"\n    \n    def test_all_command_properties(self):\n        \"\"\"Test properties of all commands\"\"\"\n        from src.commands.language import LanguageCommand\n        from src.commands.new_project import NewProjectCommand\n        from src.commands.projects import ProjectsCommand\n        from src.commands.status import StatusCommand\n        from src.commands.voice import VoiceMessageHandler\n        \n        services = {\n            'state': Mock(),\n            'project': Mock(),\n            'transcription': Mock(),\n            'config': {},\n            'logger': logging.getLogger('test')\n        }\n        \n        # Language command\n        lang = LanguageCommand(services)\n        assert lang.name == \"language\"\n        assert lang.description == \"Change language\"\n        assert lang.menu_icon == \"🌐\"\n        assert lang.show_in_menu is True\n        patterns = lang.get_callback_patterns()\n        assert \"lang_\" in patterns\n        \n        # New project command  \n        new = NewProjectCommand(services)\n        assert new.name == \"new\"\n        assert new.description == \"Create new project\"\n        assert new.menu_icon == \"➕\"\n        assert new.show_in_menu is True\n        \n        # Projects command\n        proj = ProjectsCommand(services)\n        assert proj.name == \"projects\"\n        assert proj.description == \"List projects\"\n        assert proj.menu_icon == \"📁\"\n        assert proj.show_in_menu is True\n        patterns = proj.get_callback_patterns()\n        assert \"pick_\" in patterns\n        assert \"del_\" in patterns\n        assert \"confirm_del_\" in patterns\n        assert \"cancel_del\" in patterns\n        \n        # Status command\n        status = StatusCommand(services)\n        assert status.name == \"status\"\n        assert status.description == \"Show status\"\n        assert status.menu_icon == \"📊\"\n        assert status.show_in_menu is True\n        \n        # Voice handler\n        voice = VoiceMessageHandler(services)\n        assert voice.name == \"voice\"\n        assert voice.description == \"Handle voice messages\"\n        assert voice.menu_icon == \"\"\n        assert voice.show_in_menu is False\n\n\nclass TestStateServiceEdgeCases:\n    \"\"\"Test state service edge cases\"\"\"\n   