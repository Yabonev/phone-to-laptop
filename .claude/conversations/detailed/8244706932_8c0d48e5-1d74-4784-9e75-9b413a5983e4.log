<!-- {"session_id":"8c0d48e5-1d74-4784-9e75-9b413a5983e4","transcript_path":"/Users/yabo/.claude/projects/-Users-yabo-Documents-Code-phone-to-laptop/8c0d48e5-1d74-4784-9e75-9b413a5983e4.jsonl","cwd":"/Users/yabo/Documents/Code/phone-to-laptop","hook_event_name":"PostToolUse","tool_name":"Read","tool_input":{"file_path":"/Users/yabo/Documents/Code/phone-to-laptop/pyproject.toml"},"tool_response":{"type":"text","file":{"filePath":"/Users/yabo/Documents/Code/phone-to-laptop/pyproject.toml","content":"[project]\nname = \"phone-to-laptop\"\nversion = \"0.1.0\"\ndescription = \"Add your description here\"\nreadme = \"README.md\"\nrequires-python = \">=3.11\"\ndependencies = [\n    \"openai-whisper>=20250625\",\n    \"pydantic>=2.11.7\",\n    \"python-dotenv>=1.1.1\",\n    \"python-telegram-bot>=22.3\",\n    \"rich>=14.1.0\",\n]\n","numLines":14,"startLine":1,"totalLines":14}}} -->
