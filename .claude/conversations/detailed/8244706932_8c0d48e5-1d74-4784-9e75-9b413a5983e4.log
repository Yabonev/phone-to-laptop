<!-- {"session_id":"8c0d48e5-1d74-4784-9e75-9b413a5983e4","transcript_path":"/Users/yabo/.claude/projects/-Users-yabo-Documents-Code-phone-to-laptop/8c0d48e5-1d74-4784-9e75-9b413a5983e4.jsonl","cwd":"/Users/yabo/Documents/Code/phone-to-laptop","hook_event_name":"PostToolUse","tool_name":"Edit","tool_input":{"file_path":"/Users/yabo/Documents/Code/phone-to-laptop/src/services/transcription.py","old_string":"    async def transcribe_audio(self, audio_path: Path, language: str = \"auto\") -> Tuple[str, str]:\n        \"\"\"\n        Transcribe audio file\n        Returns: (transcribed_text, detected_language)\n        \"\"\"\n        self._load_model()\n        \n        self.logger.info(f\"Transcribing audio: {audio_path} (language: {language})\")\n        \n        # Set transcription parameters\n        params = {\"fp16\": False}  # Use FP32 for CPU\n        if language != \"auto\":\n            params[\"language\"] = language\n        \n        # Transcribe\n        result = self.model.transcribe(str(audio_path), **params)\n        \n        transcribed_text = result[\"text\"].strip()\n        detected_language = result.get(\"language\", language)\n        \n        self.logger.info(f\"Transcription complete. Language: {detected_language}\")\n        \n        return transcribed_text, detected_language","new_string":"    async def transcribe_audio(self, audio_path: Path, language: str = \"auto\") -> Tuple[str, str]:\n        \"\"\"\n        Transcribe audio file\n        Returns: (transcribed_text, detected_language)\n        \"\"\"\n        self._load_model()\n        \n        self.logger.info(f\"Transcribing audio: {audio_path} (language: {language})\")\n        \n        # Set transcription parameters\n        params = {\"fp16\": False}  # Use FP32 for CPU\n        \n        if language == \"auto\":\n            # Custom auto-detect limited to English and Bulgarian\n            # First, let Whisper auto-detect\n            result = self.model.transcribe(str(audio_path), **params)\n            detected_lang = result.get(\"language\", \"en\")\n            \n            # If detected language is not English or Bulgarian, force English\n            if detected_lang not in [\"en\", \"bg\"]:\n                self.logger.info(f\"Detected {detected_lang}, not en/bg. Forcing English transcription.\")\n                params[\"language\"] = \"en\"\n                result = self.model.transcribe(str(audio_path), **params)\n                detected_lang = \"en\"\n            \n            transcribed_text = result[\"text\"].strip()\n            detected_language = detected_lang\n        else:\n            # Use specified language\n            params[\"language\"] = language\n            result = self.model.transcribe(str(audio_path), **params)\n            transcribed_text = result[\"text\"].strip()\n            detected_language = result.get(\"language\", language)\n        \n        self.logger.info(f\"Transcription complete. Language: {detected_language}\")\n        \n        return transcribed_text, detected_language"},"tool_response":{"filePath":"/Users/yabo/Documents/Code/phone-to-laptop/src/services/transcription.py","oldString":"    async def transcribe_audio(self, audio_path: Path, language: str = \"auto\") -> Tuple[str, str]:\n        \"\"\"\n        Transcribe audio file\n        Returns: (transcribed_text, detected_language)\n        \"\"\"\n        self._load_model()\n        \n        self.logger.info(f\"Transcribing audio: {audio_path} (language: {language})\")\n        \n        # Set transcription parameters\n        params = {\"fp16\": False}  # Use FP32 for CPU\n        if language != \"auto\":\n            params[\"language\"] = language\n        \n        # Transcribe\n        result = self.model.transcribe(str(audio_path), **params)\n        \n        transcribed_text = result[\"text\"].strip()\n        detected_language = result.get(\"language\", language)\n        \n        self.logger.info(f\"Transcription complete. Language: {detected_language}\")\n        \n        return transcribed_text, detected_language","newString":"    async def transcribe_audio(self, audio_path: Path, language: str = \"auto\") -> Tuple[str, str]:\n        \"\"\"\n        Transcribe audio file\n        Returns: (transcribed_text, detected_language)\n        \"\"\"\n        self._load_model()\n        \n        self.logger.info(f\"Transcribing audio: {audio_path} (language: {language})\")\n        \n        # Set transcription parameters\n        params = {\"fp16\": False}  # Use FP32 for CPU\n        \n        if language == \"auto\":\n            # Custom auto-detect limited to English and Bulgarian\n            # First, let Whisper auto-detect\n            result = self.model.transcribe(str(audio_path), **params)\n            detected_lang = result.get(\"language\", \"en\")\n            \n            # If detected language is not English or Bulgarian, force English\n            if detected_lang not in [\"en\", \"bg\"]:\n                self.logger.info(f\"Detected {detected_lang}, not en/bg. Forcing English transcription.\")\n                params[\"language\"] = \"en\"\n                result = self.model.transcribe(str(audio_path), **params)\n                detected_lang = \"en\"\n            \n            transcribed_text = result[\"text\"].strip()\n            detected_language = detected_lang\n        else:\n            # Use specified language\n            params[\"language\"] = language\n            result = self.model.transcribe(str(audio_path), **params)\n            transcribed_text = result[\"text\"].strip()\n            detected_language = result.get(\"language\", language)\n        \n        self.logger.info(f\"Transcription complete. Language: {detected_language}\")\n        \n        return transcribed_text, detected_language","originalFile":"\"\"\"\nTranscription service using Whisper - Single Responsibility\n\"\"\"\nimport tempfile\nfrom pathlib import Path\nfrom typing import Optional, Tuple\nimport whisper\nimport logging\n\n\nclass TranscriptionService:\n    \"\"\"Handles audio transcription using Whisper\"\"\"\n    \n    def __init__(self, model_name: str = \"large\", audio_dir: Path = Path(\"./audio\")):\n        self.model_name = model_name\n        self.audio_dir = audio_dir\n        self.audio_dir.mkdir(exist_ok=True)\n        self.model = None\n        self.logger = logging.getLogger(__name__)\n    \n    def _load_model(self):\n        \"\"\"Lazy load Whisper model\"\"\"\n        if self.model is None:\n            self.logger.info(f\"Loading Whisper model: {self.model_name}\")\n            self.model = whisper.load_model(self.model_name)\n            self.logger.info(\"Whisper model loaded successfully\")\n    \n    async def transcribe_audio(self, audio_path: Path, language: str = \"auto\") -> Tuple[str, str]:\n        \"\"\"\n        Transcribe audio file\n        Returns: (transcribed_text, detected_language)\n        \"\"\"\n        self._load_model()\n        \n        self.logger.info(f\"Transcribing audio: {audio_path} (language: {language})\")\n        \n        # Set transcription parameters\n        params = {\"fp16\": False}  # Use FP32 for CPU\n        if language != \"auto\":\n            params[\"language\"] = language\n        \n        # Transcribe\n        result = self.model.transcribe(str(audio_path), **params)\n        \n        transcribed_text = result[\"text\"].strip()\n        detected_language = result.get(\"language\", language)\n        \n        self.logger.info(f\"Transcription complete. Language: {detected_language}\")\n        \n        return transcribed_text, detected_language\n    \n    async def translate_to_english(self, audio_path: Path, source_language: str) -> str:\n        \"\"\"Translate audio to English\"\"\"\n        self._load_model()\n        \n        self.logger.info(f\"Translating {source_language} audio to English\")\n        \n        result = self.model.transcribe(\n            str(audio_path),\n            language=source_language,\n            task=\"translate\",  # Translate to English\n            fp16=False\n        )\n        \n        translated_text = result[\"text\"].strip()\n        self.logger.info(\"Translation complete\")\n        \n        return translated_text\n    \n    def create_temp_audio_file(self, suffix: str = '.ogg') -> Path:\n        \"\"\"Create a temporary audio file\"\"\"\n        tmp_file = tempfile.NamedTemporaryFile(\n            suffix=suffix,\n            dir=self.audio_dir,\n            delete=False\n        )\n        return Path(tmp_file.name)\n    \n    def cleanup_audio_file(self, audio_path: Path) -> None:\n        \"\"\"Delete audio file\"\"\"\n        if audio_path.exists():\n            audio_path.unlink()","structuredPatch":[{"oldStart":36,"oldLines":15,"newStart":36,"newLines":29,"lines":["         ","         # Set transcription parameters","         params = {\"fp16\": False}  # Use FP32 for CPU","-        if language != \"auto\":","+        ","+        if language == \"auto\":","+            # Custom auto-detect limited to English and Bulgarian","+            # First, let Whisper auto-detect","+            result = self.model.transcribe(str(audio_path), **params)","+            detected_lang = result.get(\"language\", \"en\")","+            ","+            # If detected language is not English or Bulgarian, force English","+            if detected_lang not in [\"en\", \"bg\"]:","+                self.logger.info(f\"Detected {detected_lang}, not en/bg. Forcing English transcription.\")","+                params[\"language\"] = \"en\"","+                result = self.model.transcribe(str(audio_path), **params)","+                detected_lang = \"en\"","+            ","+            transcribed_text = result[\"text\"].strip()","+            detected_language = detected_lang","+        else:","+            # Use specified language","             params[\"language\"] = language","+            result = self.model.transcribe(str(audio_path), **params)","+            transcribed_text = result[\"text\"].strip()","+            detected_language = result.get(\"language\", language)","         ","-        # Transcribe","-        result = self.model.transcribe(str(audio_path), **params)","-        ","-        transcribed_text = result[\"text\"].strip()","-        detected_language = result.get(\"language\", language)","-        ","         self.logger.info(f\"Transcription complete. Language: {detected_language}\")","         ","         return transcribed_text, detected_language"]}],"userModified":false,"replaceAll":false}} -->
