 InlineKeyboardMarkup(keyboard)\n        await update.message.reply_text(\"🌐 Select transcription language:\", reply_markup=reply_markup)\n    \n    async def handle_callback(self, update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:\n        \"\"\"Handle language selection\"\"\"\n        query = update.callback_query\n        await query.answer()\n        \n        lang_code = query.data.replace(\"lang_\", \"\")\n        self.state.set_language(lang_code)\n        \n        lang_names = {\n            \"en\": \"English\",\n            \"bg\": \"Bulgarian\",\n            \"auto\": \"Auto-detect\"\n        }\n        \n        lang_name = lang_names.get(lang_code, lang_code)\n        await query.edit_message_text(f\"✅ Language set to: {lang_name}\")\n        self.logger.info(f\"Language set to {lang_code}\")","numLines":66,"startLine":1,"totalLines":66}}} -->
