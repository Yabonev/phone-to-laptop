        # Verify reply was sent with buttons\\n    39→        update.message.reply_text.assert_called_once()\\n    40→        call_args = update.message.reply_text.call_args\\n    41→        \\n    42→        # Check message content\\n    43→        assert \\\"Select transcription language\\\" in call_args[0][0]\\n    44→        \\n    45→        # Check keyboard exists\\n    46→        assert 'reply_markup' in call_args[1]\\n    47→        \\n    48→    @pytest.mark.asyncio\\n    49→    async def test_language_callback_handler(self, mock_services):\\n    50→        \\\"\\\"\\\"Test language selection via callback\\\"\\\"\\\"\\n    51→        services = mock_services\\n    52→        \\n    53→        command = LanguageCommand(services)\\n    54→        \\n    55→        # Mock callback query\\n    56→        query = Mock()\\n    57→        query.data = \\\"lang_bg\\\"\\n    58→        query.answer = AsyncMock()\\n    59→        query.edit_message_text = AsyncMock()\\n    60→        \\n    61→        update = Mock()\\n    62→        update.callback_query = query\\n    63→        context = Mock()\\n    64→        \\n    65→        # Handle callback\\n    66→        await command.handle_callback(update, context)\\n    67→        \\n    68→        # Verify language was set\\n    69→        services['state'].set_language.assert_called_once_with(\\\"bg\\\")\\n    70→        \\n    71→        # Verify response\\n    72→        query.answer.assert_called_once()\\n    73→        query.edit_message_text.assert_called_once()\\n    74→        assert \\\"Bulgarian\\\" in query.edit_message_text.call_args[0][0]\\n    75→\\n    76→\\n    77→class TestStatusCommand:\\n    78→    \\\"\\\"\\\"Test status command\\\"\\\"\\\"\\n    79→    \\n    80→    @pytest.mark.asyncio\\n    81→    async def test_status_no_project(self):\\n    82→        \\\"\\\"\\\"Test status when no project selected\\\"\\\"\\\"\\n    83→        services = {\\n    84→            'state': Mock(),\\n    85→            'project': Mock(),\\n    86→            'transcription': Mock(),\\n    87→            'config': {}\\n    88→        }\\n    89→        services['state'].get_active_project.return_value = None\\n    90→        \\n    91→        command = StatusCommand(services)\\n    92→        \\n    93→        update = Mock()\\n    94→        update.message = Mock()\\n    95→        update.message.reply_text = AsyncMock()\\n    96→        context = Mock()\\n    97→        \\n    98→        await command.execute(update, context)\\n    99→        \\n   100→        # Should show no project message\\n   101→        update.message.reply_text.assert_called_once()\\n   102→        assert \\\"No active project\\\" in update.message.reply_text.call_args[0][0]\\n   103→        \\n   104→    @pytest.mark.asyncio\\n   105→    async def test_status_with_project(self, mock_services):\\n   106→        \\\"\\\"\\\"Test status with active project\\\"\\\"\\\"\\n   107→        services = mock_services\\n   108→        services['state'].get_active_project.return_value = \\\"001\\\"\\n   109→        services['state'].get_projects.return_value = {\\\"001\\\": \\\"My Project\\\"}\\n   110→        services['state'].get_language.return_value = \\\"en\\\"\\n   111→        services['project'].get_project_stats.return_value = (5, 100)\\n   112→        \\n   113→        command = StatusCommand(services)\\n   114→        \\n   115→        update = Mock()\\n   116→        update.message = Mock()\\n   117→        update.message.reply_text = AsyncMock()\\n   118→        context = Mock()\\n   119→        \\n   120→        await command.execute(update, context)\\n   121→        \\n   122→        # Should show project stats\\n   123→        update.message.reply_text.assert_called_once()\\n   124→        message = update.message.reply_text.call_args[0][0]\\n   125→        assert \\\"My Project\\\" in message\\n   126→        assert \\\"Messages: 5\\\" in message\\n   127→        assert \\\"Total words: 100\\\" in message\\n   128→        assert \\\"English\\\" in message\\n   129→\\n   130→\\n   131→class TestNewProjectCommand:\\n   132→    \\\"\\\"\\\"Test new project creation command\\\"\\\"\\\"\\n   133→    \\n   134→    @pytest.mark.asyncio\\n   135→    async def test_create_project_no_name(self):\\n   136→        \\\"\\\"\\\"Test creating project without name\\\"\\\"\\\"\\n   137→        services = {\\n   138→            'state': Mock(),\\n   139→            'project': Mock(),\\n   140→            'transcription': Mock(),\\n   141→            'config': {}\\n   142→        }\\n   143→        \\n   144→        command = NewProjectCommand(services)\\n   145→        \\n   146→        update = Mock()\\n   147→        update.message = Mock()\\n   148→        update.message.reply_text = AsyncMock()\\n   149→        context = Mock()\\n   150→        context.args = []  # No args\\n   151→        \\n   152→        await command.execute(update, context)\\n   153→        \\n   154→        # Should show usage message\\n   155→        update.message.reply_text.assert_called_once()\\n   156→        assert \\\"Usage:\\\" in update.message.reply_text.call_args[0][0]\\n   157→        \\n   158→    @pytest.mark.asyncio\\n   159→    async def test_create_project_with_name(self, mock_services):\\n   160→        \\\"\\\"\\\"Test creating project with name\\\"\\\"\\\"\\n   161→        services = mock_services\\n   162→        services['state'].get_projects.return_value = {}\\n   163→        services['project'].create_project.return_value = \\\"001\\\"\\n   164→        \\n   165→        command = NewProjectCommand(services)\\n   166→        \\n   167→        update = Mock()\\n   168→        update.message = Mock()\\n   169→        update.message.reply_text = AsyncMock()\\n   170→        context = Mock()\\n   171→        context.args = [\\\"My\\\", \\\"Test\\\", \\\"Project\\\"]\\n   172→        \\n   173→        await command.execute(update, context)\\n   174→        \\n   175→        # Verif